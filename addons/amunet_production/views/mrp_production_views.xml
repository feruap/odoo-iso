<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Inherit mrp.production form view -->
        <record id="view_mrp_production_form_amunet_inherit" model="ir.ui.view">
            <field name="name">mrp.production.form.amunet.inherit</field>
            <field name="model">mrp.production</field>
            <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
            <field name="arch" type="xml">

                <!-- Botones de accion en header -->
                <xpath expr="//header" position="inside">
                    <button name="action_request_analysis" string="Confirmar análisis" type="object" class="oe_highlight" invisible="state == 'done' or amunet_sys_req_qc == False or quality_analysis_status in ('requested', 'approved')"/>
                    <button name="%(amunet_production.action_report_production_zebra_label)d" string="Imprimir Etiqueta" type="action" class="oe_highlight" invisible="not amunet_all_ingredients_valid"/>
                </xpath>

                <!-- Ocultar botones nativos no requeridos -->
                <xpath expr="//button[@name='action_confirm']" position="attributes">
                    <attribute name="invisible">state != 'draft' or amunet_is_solution_product</attribute>
                </xpath>
                <xpath expr="//button[@name='action_start']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//button[@name='do_unreserve']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//button[@name='button_plan']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//button[@name='button_unplan']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>

                <!-- Lote: renombrar label y hacerlo visible desde borrador -->
                <xpath expr="//label[@for='lot_producing_ids']" position="attributes">
                    <attribute name="string">Lote de produccion (Asignado)</attribute>
                    <attribute name="invisible">state == 'cancel' or product_tracking in ('none', False) or (state == 'done' and product_tracking == 'serial' and product_qty &gt; 1)</attribute>
                </xpath>
                <!-- Div contenedor del campo nativo: Oculto en borrador porque no existe lote físico aún -->
                <xpath expr="//div[field[@name='lot_producing_ids']]" position="attributes">
                    <attribute name="invisible">state in ('draft', 'cancel') or product_tracking in ('none', False) or (state == 'done' and product_tracking == 'serial' and product_qty &gt; 1)</attribute>
                </xpath>

                <!-- Campo previsualizado en borrador -->
                <xpath expr="//div[field[@name='lot_producing_ids']]" position="after">
                    <div class="o_row" invisible="state != 'draft' or product_tracking in ('none', False)">
                        <field name="solution_lot_id" readonly="0" decoration-warning="1" class="fw-bold"/>
                        <span class="text-muted ms-2">(Editable antes de confirmar)</span>
                    </div>
                </xpath>

                <!-- Ocultar botón nativo de generar lote en borrador (todas las variantes) -->
                <xpath expr="//button[@name='action_generate_serial'][1]" position="attributes">
                    <attribute name="invisible">state in ('draft', 'cancel') or product_tracking in ('none', 'lot', False) or lot_producing_ids</attribute>
                </xpath>
                <xpath expr="//button[@name='action_generate_serial'][2]" position="attributes">
                    <attribute name="invisible">state in ('draft', 'cancel') or product_tracking in ('none', 'lot', False) or not lot_producing_ids or product_qty == 1</attribute>
                </xpath>
                <xpath expr="//button[@name='action_generate_serial'][3]" position="attributes">
                    <attribute name="invisible">state in ('draft', 'cancel') or product_tracking in ('none', 'serial', False) or lot_producing_ids</attribute>
                </xpath>

                <!-- Campos adicionales debajo del bloque de BoM -->
                <xpath expr="//div[@name='bom_div']" position="after">
                    <label for="quality_ph_initial" string="Control de pH" invisible="quality_ph_initial == 0.0"/>
                    <div class="o_row" invisible="quality_ph_initial == 0.0">
                        Inicial: <field name="quality_ph_initial" readonly="1" force_save="1" style="width:50px"/>
                        | Rango: <field name="amunet_sys_ph_range" readonly="1"/>
                        <!-- pH Final editable y visible solo cuando todos los ingredientes esten validados -->
                        <span invisible="not amunet_all_ingredients_valid">
                            | Final: <field name="quality_ph_final" readonly="0"/>
                        </span>
                    </div>

                    <label for="solution_expiration_date" string="Caducidad"/>
                    <div class="o_row">
                        <field name="solution_expiration_date" force_save="1"/>
                        <field name="amunet_expiration_text" readonly="1" force_save="1" class="text-muted"/>
                    </div>
                    <field name="quality_analysis_status" readonly="1" force_save="1" decoration-info="quality_analysis_status == 'requested'" decoration-success="quality_analysis_status == 'approved'" decoration-danger="quality_analysis_status == 'rejected'"/>
                    <field name="amunet_all_ingredients_valid" invisible="1"/>
                    <field name="amunet_sys_req_qc" invisible="1"/>
                </xpath>

                <!-- Ocultar pestana Miscelaneo nativa -->
                <xpath expr="//page[@name='miscellaneous']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>

                <!-- Permitir fabricar productos con BoM: soluciones y pruebas rapidas ruta corta. -->
                <xpath expr="//field[@name='product_id']" position="attributes">
                    <attribute name="domain">[('bom_ids', '!=', False)]</attribute>
                </xpath>

                <!-- Categoria del producto seleccionado (solo lectura) -->
                <xpath expr="//field[@name='product_id']" position="after">
                    <field name="amunet_product_categ_id" string="Categoria" readonly="1"/>
                    <field name="amunet_is_solution_product" invisible="1"/>
                </xpath>
                <!-- Ocultar widget nativo date_start; mostrar campo computado con formato DD/MM/YY HH:MM AM/PM -->
                <xpath expr="//field[@name='date_start']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//div[@name='date_start']" position="after">
                    <field name="amunet_scheduled_date_display" readonly="1"/>
                </xpath>

                <!-- TABLA DE INGREDIENTES orden: producto | por consumir | lote | cant.utilizada | disolucion | valido -->

                <!-- 1. Lote del ingrediente despues de "Por consumir" -->
                <xpath expr="//field[@name='move_raw_ids']/list/field[@name='product_uom_qty'][@widget='mrp_should_consume']" position="after">
                    <field name="amunet_lot_id"
                        domain="[('product_id', '=', product_id)]"
                        context="{'default_product_id': product_id}"
                        options="{'no_create': True, 'no_create_edit': True, 'no_open': True}"
                        string="Lote"
                        optional="show"/>
                </xpath>

                <!-- 2. Renombrar Cantidad Utilizada y asegurar visibilidad -->
                <xpath expr="//field[@name='move_raw_ids']/list/field[@name='quantity']" position="attributes">
                    <attribute name="string">Cantidad Utilizada</attribute>
                    <attribute name="column_invisible">False</attribute>
                </xpath>

                <!-- 3. Insertar Disolucion y Valido despues de Cantidad Utilizada -->
                <xpath expr="//field[@name='move_raw_ids']/list/field[@name='quantity']" position="after">
                    <field name="amunet_dissolution" widget="boolean_toggle" string="Disolucion"/>
                    <field name="amunet_is_valid"
                        widget="boolean"
                        readonly="1"
                        string="Valido"
                        decoration-success="amunet_is_valid == True"
                        decoration-danger="amunet_is_valid == False"/>
                </xpath>

                <!-- Ocultar badge de disponibilidad nativo -->
                <xpath expr="//field[@name='move_raw_ids']/list/field[@name='forecast_availability']" position="attributes">
                    <attribute name="column_invisible">True</attribute>
                </xpath>

            </field>
        </record>

    </data>
</odoo>

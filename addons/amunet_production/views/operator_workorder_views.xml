<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mrp_workorder_operator_search" model="ir.ui.view">
        <field name="name">mrp.workorder.operator.search</field>
        <field name="model">mrp.workorder</field>
        <field name="arch" type="xml">
            <search string="Mi trabajo de produccion">
                <field name="name"/>
                <field name="production_id"/>
                <field name="product_id"/>
                <field name="workcenter_id"/>
                <filter name="ready" string="Listas para iniciar" domain="[('state', '=', 'ready')]"/>
                <filter name="progress" string="En progreso" domain="[('state', '=', 'progress')]"/>
                <filter name="blocked" string="En espera" domain="[('state', '=', 'blocked')]"/>
            </search>
        </field>
    </record>

    <record id="view_mrp_workorder_operator_kanban" model="ir.ui.view">
        <field name="name">mrp.workorder.operator.kanban</field>
        <field name="model">mrp.workorder</field>
        <field name="arch" type="xml">
            <kanban create="0" delete="0" group_create="0" class="o_kanban_mobile">
                <field name="name"/>
                <field name="state"/>
                <field name="production_id"/>
                <field name="product_id"/>
                <field name="workcenter_id"/>
                <field name="qty_remaining"/>
                <field name="qty_produced"/>
                <field name="is_user_working"/>
                <field name="amunet_operator_next_step"/>
                <field name="amunet_operator_material_status"/>
                <field name="amunet_operator_quality_status"/>
                <field name="amunet_operator_time_status"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                    <div class="text-muted">
                                        <field name="production_id"/>
                                    </div>
                                </div>
                                <span class="badge text-bg-secondary">
                                    <field name="state"/>
                                </span>
                            </div>
                            <div class="o_kanban_record_body mt-2">
                                <div><strong>Producto:</strong> <field name="product_id"/></div>
                                <div><strong>Area:</strong> <field name="workcenter_id"/></div>
                                <div><strong>Siguiente:</strong> <field name="amunet_operator_next_step"/></div>
                                <div><strong>Material:</strong> <field name="amunet_operator_material_status"/></div>
                                <div><strong>Calidad:</strong> <field name="amunet_operator_quality_status"/></div>
                                <div><strong>Tiempo:</strong> <field name="amunet_operator_time_status"/></div>
                            </div>
                            <div class="o_kanban_record_bottom mt-3">
                                <button t-if="record.state.raw_value == 'ready'"
                                        name="action_amunet_operator_start"
                                        type="object"
                                        class="btn btn-primary"
                                        string="Iniciar"/>
                                <button t-if="record.state.raw_value == 'progress'"
                                        name="action_amunet_operator_finish"
                                        type="object"
                                        class="btn btn-success"
                                        string="Terminar"/>
                                <button name="action_amunet_open_production"
                                        type="object"
                                        class="btn btn-secondary"
                                        string="Ver orden"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_mrp_workorder_operator_list" model="ir.ui.view">
        <field name="name">mrp.workorder.operator.list</field>
        <field name="model">mrp.workorder</field>
        <field name="arch" type="xml">
            <list create="0" delete="0" edit="0" decoration-success="state == 'ready'" decoration-info="state == 'progress'" decoration-muted="state == 'blocked'">
                <button name="action_amunet_operator_start" type="object" icon="fa-play" title="Iniciar" invisible="state != 'ready'"/>
                <button name="action_amunet_operator_finish" type="object" icon="fa-check" title="Terminar" invisible="state != 'progress'"/>
                <field name="name" string="Operacion"/>
                <field name="production_id" string="Orden de fabricacion"/>
                <field name="product_id" string="Producto"/>
                <field name="workcenter_id" string="Area"/>
                <field name="state" string="Estado"/>
                <field name="amunet_operator_next_step"/>
                <field name="amunet_operator_material_status"/>
                <field name="amunet_operator_quality_status"/>
                <field name="qty_remaining" string="Cantidad por producir"/>
                <field name="qty_produced" string="Cantidad realizada"/>
            </list>
        </field>
    </record>

    <record id="view_mrp_production_operator_form" model="ir.ui.view">
        <field name="name">mrp.production.operator.form</field>
        <field name="model">mrp.production</field>
        <field name="arch" type="xml">
            <form string="Orden de fabricacion" create="0" delete="0" edit="0">
                <header>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" string="Orden" readonly="1"/>
                            <field name="product_id" string="Producto" readonly="1"/>
                            <field name="product_qty" string="Cantidad" readonly="1"/>
                            <field name="product_uom_id" string="Unidad" readonly="1"/>
                        </group>
                        <group>
                            <field name="origin" string="Origen" readonly="1"/>
                            <field name="date_start" string="Inicio programado" readonly="1"/>
                            <field name="date_finished" string="Fin programado" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Operaciones">
                            <field name="workorder_ids" readonly="1">
                                <list create="0" delete="0" edit="0">
                                    <field name="name" string="Operacion"/>
                                    <field name="workcenter_id" string="Area"/>
                                    <field name="state" string="Estado"/>
                                    <field name="qty_remaining" string="Cantidad por producir"/>
                                    <field name="qty_produced" string="Cantidad realizada"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_mrp_workorder_operator_form" model="ir.ui.view">
        <field name="name">mrp.workorder.operator.form</field>
        <field name="model">mrp.workorder</field>
        <field name="arch" type="xml">
            <form string="Trabajo de produccion" create="0" delete="0" edit="0">
                <header>
                    <button name="action_amunet_operator_start" string="Iniciar operacion" type="object" class="oe_highlight" invisible="state != 'ready'"/>
                    <button name="action_amunet_operator_finish" string="Terminar operacion" type="object" class="oe_highlight" invisible="state != 'progress'"/>
                    <button name="action_amunet_open_production" string="Ver orden" type="object"/>
                    <field name="state" widget="statusbar" statusbar_visible="blocked,ready,progress,done"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" string="Operacion" readonly="1"/>
                            <field name="production_id" string="Orden de fabricacion" readonly="1"/>
                            <field name="product_id" string="Producto" readonly="1"/>
                            <field name="workcenter_id" string="Area" readonly="1"/>
                        </group>
                        <group>
                            <field name="amunet_operator_next_step" readonly="1"/>
                            <field name="amunet_operator_material_status" readonly="1"/>
                            <field name="amunet_operator_quality_status" readonly="1"/>
                            <field name="amunet_operator_time_status" readonly="1"/>
                        </group>
                    </group>
                    <group string="Cantidad y tiempo">
                        <field name="qty_remaining" string="Cantidad por producir" readonly="1"/>
                        <field name="qty_produced" string="Cantidad realizada" readonly="1"/>
                        <field name="duration_expected" string="Duracion esperada" readonly="1"/>
                        <field name="duration" string="Tiempo real" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_amunet_operator_workorders" model="ir.actions.act_window">
        <field name="name">Mi trabajo de produccion</field>
        <field name="res_model">mrp.workorder</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', 'not in', ('done', 'cancel'))]</field>
        <field name="context">{}</field>
        <field name="search_view_id" ref="view_mrp_workorder_operator_search"/>
        <field name="view_id" ref="view_mrp_workorder_operator_list"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_empty_folder">
                No hay operaciones abiertas para produccion.
            </p>
            <p>
                Cuando el supervisor confirme una orden, aqui apareceran las operaciones listas para iniciar,
                en progreso o en espera de materiales.
            </p>
        </field>
    </record>

    <record id="action_amunet_operator_workorders_view_list" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_mrp_workorder_operator_list"/>
        <field name="act_window_id" ref="action_amunet_operator_workorders"/>
    </record>

    <record id="action_amunet_operator_workorders_view_form" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_mrp_workorder_operator_form"/>
        <field name="act_window_id" ref="action_amunet_operator_workorders"/>
    </record>

    <menuitem id="menu_amunet_production_root"
              name="Produccion Amunet"
              sequence="35"
              web_icon="mrp,static/description/icon.png"
              groups="amunet_production.group_production_operator,amunet_production.group_production_supervisor"/>

    <menuitem id="menu_amunet_operator_workorders"
              name="Mi trabajo"
              parent="menu_amunet_production_root"
              action="action_amunet_operator_workorders"
              sequence="10"
              groups="amunet_production.group_production_operator,amunet_production.group_production_supervisor"/>

    <menuitem id="menu_amunet_supervisor_mo"
              name="Ordenes de fabricacion"
              parent="menu_amunet_production_root"
              action="mrp.mrp_production_action"
              sequence="20"
              groups="amunet_production.group_production_supervisor"/>
</odoo>

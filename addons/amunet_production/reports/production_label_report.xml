<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Omitimos el tamaño de papel estricto a petición del usuario para que sea hoja normal -->
        <!-- Acción del Reporte de Odoo -->
        <record id="action_report_production_zebra_label" model="ir.actions.report">
            <field name="name">Etiqueta de Solución (Zebra)</field>
            <field name="model">mrp.production</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">amunet_production.report_solution_label</field>
            <field name="report_file">amunet_production.report_solution_label</field>
            <field name="binding_model_id" ref="mrp.model_mrp_production"/>
            <field name="binding_type">report</field>
        </record>

        <!-- QWeb Template (Diseño Visual) -->
        <template id="report_solution_label">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-call="web.basic_layout">
                        <div class="page" style="font-family: Arial, sans-serif; font-size: 22pt; line-height: 1.5; width: 100%; height: 100%; padding: 20px; margin: 0; overflow: hidden;">
                            <!-- Header: Nombre -->
                            <div style="font-weight: bold; font-size: 26pt; margin-bottom: 20px; text-align: left; width: 100%; border-bottom: 2px dashed #000; padding-bottom: 10px;">
                                <span>Nombre: </span><span t-field="o.product_id.name"/>
                            </div>
                            
                            <!-- Row 1: Fecha / pH -->
                            <div style="width: 100%; display: table; margin-bottom: 15px;">
                                <div style="display: table-cell; width: 60%; text-align: left;">
                                    <strong>Fecha: </strong>
                                    <span t-if="o.date_finished" t-field="o.date_finished" t-options='{"widget": "date"}'/>
                                    <span t-if="not o.date_finished" t-field="o.date_start" t-options='{"widget": "date"}'/>
                                </div>
                                <div style="display: table-cell; width: 40%; text-align: right;">
                                    <strong>pH: </strong>
                                    <span t-field="o.quality_ph_initial" t-options='{"widget": "float", "precision": 2}'/>
                                </div>
                            </div>
                            
                            <!-- Row 2: Lote / Caducidad -->
                            <div style="width: 100%; display: table; margin-bottom: 30px;">
                                <div style="display: table-cell; width: 60%; text-align: left;">
                                    <strong>Lote: </strong>
                                    <span t-if="o.solution_lot_id" t-field="o.solution_lot_id"/>
                                    <span t-if="not o.solution_lot_id">N/A</span>
                                </div>
                                <div style="display: table-cell; width: 40%; text-align: right;">
                                    <strong>Caducidad: </strong>
                                    <span t-if="o.solution_expiration_date" t-field="o.solution_expiration_date" t-options='{"widget": "date"}'/>
                                    <span t-if="not o.solution_expiration_date">N/A</span>
                                </div>
                            </div>
                            
                            <!-- Footer: Elaboró -->
                            <div style="width: 100%; text-align: left; margin-top: 20px; border-top: 2px dashed #000; padding-top: 15px;">
                                <strong>Elaboró: </strong>
                                <span t-if="o.user_id" t-field="o.user_id.name"/>
                                <span t-if="not o.user_id">N/A</span>
                            </div>
                        </div>
                    </t>
                </t>
            </t>
        </template>

    </data>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vista Tree (Listado) -->
    <record id="view_amunet_transfer_bom_tree" model="ir.ui.view">
        <field name="name">amunet.transfer.bom.tree</field>
        <field name="model">amunet.transfer.bom</field>
        <field name="arch" type="xml">
            <list string="Listas de materiales para entregas">
                <field name="name"/>
                <field name="product_id"/>
                <field name="product_qty"/>
                <field name="product_uom_id" groups="uom.group_uom"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Vista Form (Formulario) -->
    <record id="view_amunet_transfer_bom_form" model="ir.ui.view">
        <field name="name">amunet.transfer.bom.form</field>
        <field name="model">amunet.transfer.bom</field>
        <field name="arch" type="xml">
            <form string="Lista de materiales para entrega">
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <widget name="web_ribbon" title="Archivado" bg_color="text-bg-danger" invisible="active"/>
                    <group>
                        <group>
                            <field name="product_id"/>
                            <field name="product_qty"/>
                            <field name="product_uom_id" groups="uom.group_uom"/>
                        </group>
                        <group>
                            <field name="active" invisible="1"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Componentes" name="components">
                            <field name="bom_line_ids">
                                <list string="Componentes" editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id"/>
                                    <field name="product_qty"/>
                                    <field name="product_uom_id" groups="uom.group_uom"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Acción -->
    <record id="action_amunet_transfer_bom" model="ir.actions.act_window">
        <field name="name">Listas de materiales para entregas</field>
        <field name="res_model">amunet.transfer.bom</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crear una nueva lista de materiales
            </p>
            <p>
                Las listas de materiales permiten definir qué componentes se deben agregar automáticamente
                al crear entregas de productos compuestos.
            </p>
        </field>
    </record>

</odoo>

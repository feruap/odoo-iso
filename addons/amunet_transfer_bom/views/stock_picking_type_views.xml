<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Extender vista de formulario de Tipo de Operación -->
    <record id="view_picking_type_form_bom" model="ir.ui.view">
        <field name="name">stock.picking.type.form.bom</field>
        <field name="model">stock.picking.type</field>
        <field name="inherit_id" ref="stock.view_picking_type_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='code']" position="after">
                <field name="enable_bom_transfer" invisible="code != 'outgoing'"/>
            </xpath>
        </field>
    </record>

</odoo>

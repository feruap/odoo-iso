<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mrp_production_form_rework_inherit" model="ir.ui.view">
        <field name="name">mrp.production.form.rework.inherit</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_create_rework_order"
                        string="No conformidad / reproceso"
                        type="object"
                        invisible="state in ('draft', 'cancel')"
                        groups="amunet_production.group_production_supervisor,amunet_quality.group_quality_supervisor,amunet_quality.group_quality_manager"/>
            </xpath>
            <xpath expr="//sheet" position="inside">
                <field name="rework_order_count" invisible="1"/>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_rework_orders"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-retweet"
                        invisible="rework_order_count == 0">
                    <field name="rework_order_count" widget="statinfo" string="Reprocesos"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>

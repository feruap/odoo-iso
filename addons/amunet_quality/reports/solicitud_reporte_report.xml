<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="paperformat_solicitud_reporte" model="report.paperformat">
        <field name="name">Solicitud Reporte Amunet</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">40</field>
        <field name="header_spacing">35</field>
        <field name="margin_bottom">15</field>
        <field name="margin_left">10</field>
        <field name="margin_right">10</field>
        <field name="header_line" eval="False"/>
        <field name="dpi">90</field>
    </record>

    <record id="action_report_solicitud_reporte_v2" model="ir.actions.report">
        <field name="name">Solicitud Reporte</field>
        <field name="model">amunet.quality.check</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">amunet_quality.report_solicitud_reporte_template_v2</field>
        <field name="report_file">amunet_quality.report_solicitud_reporte_template_v2</field>
        <field name="print_report_name">'Solicitud - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_amunet_quality_check"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_solicitud_reporte"/>
    </record>

    <template id="report_solicitud_reporte_template_v2">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                
                <div class="header" style="font-family: Cambria, serif; font-size: 11pt; color: #000; width: 100%; padding-top: 0px;">
                    <style>
                        .no-border {
                            border: 0px solid transparent !important;
                        }
                    </style>
                    <table style="width: 100%; border-collapse: separate; border-spacing: 0; border: 0 !important;">
                        <tr>
                            <td class="no-border" style="width: 20%; text-align: center; vertical-align: middle; border: 0 !important; padding: 0;">
                                <img t-if="o.company_id.logo" t-att-src="'data:image/png;base64,' + o.company_id.logo.decode()" style="max-height:80px; margin: 0 auto; display: block;"/>
                            </td>
                            <td class="no-border" style="width: 50%; text-align: center; vertical-align: bottom; color: #003399; border: 0 !important; padding: 0 0 5px 0;">
                                <div style="border-bottom: 12px solid #e0e0e0; width: 100%; margin: 0 auto; padding-bottom: 2px;">
                                    <span style="font-weight: bold; font-size: 14pt;">SOLICITUD-REPORTE</span><br/>
                                    <span style="font-weight: bold; font-size: 14pt;" t-esc="o.product_id.categ_id.complete_name.split('/')[0].strip() if o.product_id.categ_id else ''"/>
                                </div>
                            </td>
                            
                            <td style="width: 30%; border: 0 !important; padding: 0; vertical-align: middle; text-align: right;">
                                <table style="width: 85%; margin-left: auto; border-collapse: collapse; border: 1px solid black; font-size: 8pt; line-height: 1.1;">
                                    <tr>
                                        <td style="padding: 1px 3px; border-bottom: 1px solid black; border-right: none; border-left: none; text-align: left; font-weight: bold;">Fecha de elaboración:</td>
                                        <td style="padding: 1px 3px; border-bottom: 1px solid black; border-right: none; border-left: none; text-align: right;">
                                            <t t-if="o.product_id.report_effective_date">
                                                <span t-esc="'%s.%s' % (['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'][o.product_id.report_effective_date.month - 1], o.product_id.report_effective_date.year)"/>
                                            </t>
                                            <t t-else="">
                                                <span t-esc="'%s.%s' % (['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'][o.create_date.month - 1], o.create_date.year)"/>
                                            </t>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 1px 3px; border-bottom: 1px solid black; border-right: none; border-left: none; text-align: left; font-weight: bold;">Fecha de vigencia:</td>
                                        <td style="padding: 1px 3px; border-bottom: 1px solid black; border-right: none; border-left: none; text-align: right;">
                                            <t t-if="o.product_id.report_expiry_date">
                                                <span t-esc="'%s.%s' % (['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'][o.product_id.report_expiry_date.month - 1], o.product_id.report_expiry_date.year)"/>
                                            </t>
                                            <t t-else="">
                                                <span t-esc="'%s.%s' % (['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'][o.expiration_date.month - 1], o.expiration_date.year) if o.expiration_date else ''"/>
                                            </t>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 1px 3px; border-bottom: 1px solid black; border-right: none; border-left: none; text-align: left; font-weight: bold;">Código:</td>
                                        <td style="padding: 1px 3px; border-bottom: 1px solid black; border-right: none; border-left: none; text-align: right;"><span t-field="o.product_id.report_document_code"/></td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 1px 3px; border-bottom: 1px solid black; border-right: none; border-left: none; text-align: left; font-weight: bold;">Versión:</td>
                                        <td style="padding: 1px 3px; border-bottom: 1px solid black; border-right: none; border-left: none; text-align: right;"><span t-field="o.product_id.report_version"/></td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 1px 3px; border-bottom: 1px solid black; border-right: none; border-left: none; text-align: left; font-weight: bold;">Sustituye:</td>
                                        <td style="padding: 1px 3px; border-bottom: 1px solid black; border-right: none; border-left: none; text-align: right;"><span t-field="o.product_id.report_replaces_version"/></td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 1px 3px; border: none; text-align: left; font-weight: bold;">Pág.:</td>
                                        <td style="padding: 1px 3px; border: none; text-align: right;"><span class="page"/> de <span class="topage"/></td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                    </table>
                </div>

                <div class="article page" style="font-family: Cambria, serif; font-size: 11pt; color: #000; width: 100%;">
                    
                    <style>
                        .tabla-full { width: 100%; border-collapse: collapse; }
                        .tabla-datos td { border: 1px solid #000; padding: 4px; vertical-align: top; }
                        .no-border, .no-border td { border: 0 !important; }
                    </style>

                    <div style="font-weight: bold; margin-top: 15px; margin-bottom: 5px; font-size: 14pt;">
                        1.- Datos Generales
                    </div>
                    <table class="no-border" style="width: 100%; border: 0px none transparent !important; font-size: 11pt; margin-bottom: 10px; line-height: 1.5;">
                        <tr style="border: 0 !important;">
                            <td class="no-border" style="width: 70%; border: 0px none transparent !important; padding: 2px 0;"><strong>Nombre:</strong> <span t-field="o.product_id.name"/></td>
                            <td class="no-border" style="width: 30%; border: 0px none transparent !important; padding: 2px 0;"><strong>Clave:</strong> <span t-field="o.product_code"/></td>
                        </tr>
                        <tr style="border: 0 !important;">
                            <td class="no-border" colspan="2" style="border: 0px none transparent !important; padding: 2px 0;"><strong>Descripción:</strong> <span t-field="o.product_description"/></td>
                        </tr>
                    </table>

                    <div style="font-weight: bold; margin-top: 15px; margin-bottom: 5px; font-size: 14pt;">
                        2.- Solicitud de análisis de muestreo
                    </div>
                    <table class="no-border" style="width: 100%; border: 0px none transparent !important; font-size: 11pt; margin-bottom: 10px; line-height: 1.2;">
                        <tr style="border: 0 !important;">
                            <td class="no-border" style="width: 50%; border: 0px none transparent !important; padding: 2px 0;">Fecha de solicitud: <span t-field="o.request_date"/></td>
                            <td class="no-border" style="width: 50%; border: 0px none transparent !important; padding: 2px 0;">Solicitante: <span t-field="o.requester_id.name"/></td>
                        </tr>
                    </table>

                    <div style="font-weight: bold; margin-top: 15px; margin-bottom: 5px; font-size: 14pt;">
                        3.- Información del producto
                    </div>
                    <table class="tabla-full tabla-datos" style="text-transform: uppercase;">
                        <tr style="background-color: #f2f2f2; text-align: center;">
                            <td style="width: 50%;">ORIGEN</td>
                            <td style="width: 50%;">USUARIO</td>
                        </tr>
                        <tr>
                            <td>FABRICANTE: <span t-field="o.partner_id.name"/></td>
                            <td>NO. DE LOTE AMUNET: <span t-field="o.lot_name_amunet"/></td>
                        </tr>
                        <tr>
                            <td>LOTE DE FÁBRICA: <span t-field="o.lot_name_factory"/></td>
                            <td>CANTIDAD DEL LOTE: <span t-field="o.lot_qty_available"/></td>
                        </tr>
                        <tr>
                            <td>FECHA DE FABRICACIÓN: <span t-field="o.manufacturing_date"/></td>
                            <td>FECHA DE CADUCIDAD: <span t-field="o.expiration_date"/></td>
                        </tr>
                        <tr>
                            <td colspan="2">REVISADO POR: <span t-field="o.inventory_validator_id.name"/></td>
                        </tr>
                    </table>

                    <div style="font-weight: bold; margin-top: 15px; margin-bottom: 5px; font-size: 14pt;">
                        4.- Muestreo
                    </div>
                    <table class="tabla-full tabla-datos" style="text-transform: uppercase; margin-bottom: 10px;">
                        <tr>
                            <td style="width: 50%;">FECHA DE MUESTREO: <span t-field="o.sampling_date"/></td>
                            <td style="width: 50%;">CANTIDAD MUESTREADA: <span t-field="o.qty_sampling"/></td>
                        </tr>
                        <tr>
                            <td style="width: 50%;">MUESTREADO POR: <span t-field="o.user_realized_id.name"/></td>
                            <td style="width: 50%;">VERIFICA: <span t-field="o.inventory_validator_id.name"/></td>
                        </tr>
                    </table>

                    <div style="font-weight: bold; margin-top: 15px; margin-bottom: 5px; font-size: 14pt;">
                        5.- Análisis
                    </div>
                    <table class="tabla-full tabla-datos" style="text-transform: uppercase; margin-bottom: 10px;">
                        <tr>
                            <td style="width: 50%;">FECHA DE ANÁLISIS: <span t-field="o.analysis_date"/></td>
                            <td style="width: 50%;">FECHA DE REANÁLISIS:</td>
                        </tr>
                        <tr>
                            <td style="width: 50%;">NO. DE ANÁLISIS: <span t-esc="o.analysis_number"/></td>
                            <td style="width: 50%;">TIPO DE ANÁLISIS: <span t-field="o.analysis_type"/></td>
                        </tr>
                    </table>

                    <div style="font-weight: bold; margin-top: 15px; margin-bottom: 5px; font-size: 14pt;">
                        6.- Pruebas realizadas
                    </div>
                    <table class="tabla-full tabla-datos">
                        <tr style="background-color: #f2f2f2;">
                            <td style="width: 35%;">Nombre / Código</td>
                            <td style="width: 65%;">DESCRIPCIÓN DEL RESULTADO</td>
                        </tr>
                        <t t-foreach="o.test_line_ids" t-as="line">
                            <tr>
                                <td>
                                    <span t-field="line.name"/><br/>
                                    <span t-field="line.code"/>
                                </td>
                                <td>
                                    <t t-foreach="line.detail_line_ids" t-as="detail">
                                        <div>
                                            <t t-if="detail.verdict == 'pass'">☑</t>
                                            <t t-if="detail.verdict != 'pass'">☐</t>
                                            <span t-field="detail.name"/>:
                                            <span t-field="detail.result_display"/>
                                        </div>
                                    </t>
                                </td>
                            </tr>
                        </t>
                    </table>

                    <div style="font-weight: bold; margin-top: 15px; font-size: 14pt;">
                        7.- Referencias
                    </div>
                    <div style="padding-top: 5px; padding-bottom: 10px; font-size: 11pt;">
                        <t t-if="o.reference_ids">
                            <ul style="margin: 0; padding-left: 20px;">
                                <t t-foreach="o.reference_ids" t-as="ref">
                                    <li><span t-field="ref.name"/></li>
                                </t>
                            </ul>
                        </t>
                        <t t-elif="o.product_id.report_references">
                            <span t-field="o.product_id.report_references"/>
                        </t>
                        <t t-else="">
                            No asignadas
                        </t>
                    </div>

                    <div style="width: 100%; margin-top: 40px; page-break-inside: avoid;">
                        <table style="width: 100%; text-align: center; border: 0 !important; border-collapse: separate; border-spacing: 0;">
                            <tr>
                                <td class="no-border" style="width: 45%; vertical-align: bottom; border: 0 !important;">
                                    <div style="margin-bottom: 5px; min-height: 45px; font-weight: bold;">
                                        <span t-field="o.realized_date"/><br/>
                                        <span t-field="o.user_realized_id.name"/><br/>
                                        <span t-field="o.user_realized_id.job_title"/>
                                    </div>
                                    <div style="border-top: 1px solid black; padding-top: 5px; width: 80%; margin: 0 auto; font-weight: bold;">
                                        REALIZÓ<br/>
                                        (Fecha, Nombre, Puesto)
                                    </div>
                                </td>
                                <td class="no-border" style="width: 10%; border: 0 !important;"></td>
                                <td class="no-border" style="width: 45%; vertical-align: bottom; border: 0 !important;">
                                    <div style="margin-bottom: 5px; min-height: 45px; font-weight: bold;">
                                        <span t-field="o.verified_date"/><br/>
                                        <span t-field="o.user_verified_id.name"/><br/>
                                        <span t-field="o.user_verified_id.job_title"/>
                                    </div>
                                    <div style="border-top: 1px solid black; padding-top: 5px; width: 80%; margin: 0 auto; font-weight: bold;">
                                        VERIFICÓ<br/>
                                        (Fecha, Nombre, Puesto)
                                    </div>
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>

                <!-- ═══ PÁGINA DE ANEXO (hoja extra, sin firmas) ═══ -->
                <t t-if="o.tiene_anexos">
                    <div style="page-break-before: always;"/>
                    <t t-call="amunet_quality.report_anexo_solicitud_template_inner"/>
                </t>

                <div class="footer" style="width: 100%; text-align: center; font-size: 11pt; font-weight: bold; font-style: italic; font-family: Cambria, serif;">
                    Este documento es confidencial. Uso exclusivo de Amunet S.A. de C.V.
                </div>

            </t>
        </t>
    </template>

    <!-- Template interno del anexo (sin web.html_container, para embeber) -->
    <template id="report_anexo_solicitud_template_inner">
        <div class="page" style="font-family: Arial, sans-serif; padding: 10px;">

            <!-- ═══ TABLA PRINCIPAL DEL ANEXO ═══ -->
            <table style="width: 100%; border-collapse: collapse; margin: 0 auto;">

                <!-- Fila 1: Título -->
                <tr>
                    <td colspan="7"
                        style="text-align: center; font-weight: bold; font-size: 14pt;
                               background-color: #D9D9D9; border: 1px solid #4472C4;
                               padding: 6px 4px;">
                        <t t-esc="o.anexo_titulo or 'ANEXO GENERAL'"/>
                    </td>
                </tr>

                <!-- Fila 2: Fecha | No. Análisis -->
                <tr>
                    <td colspan="4"
                        style="font-weight: bold; background-color: #D9D9D9;
                               border: 1px solid #4472C4; padding: 4px 6px;">
                        Fecha:
                        <span style="font-weight: normal;">
                            <t t-esc="o.analysis_date and o.analysis_date.strftime('%d/%m/%Y') or (o.date_done and o.date_done.strftime('%d/%m/%Y')) or ''"/>
                        </span>
                    </td>
                    <td colspan="3"
                        style="font-weight: bold; background-color: #D9D9D9;
                               border: 1px solid #4472C4; padding: 4px 6px;">
                        No. Análisis:
                        <span style="font-weight: normal;">
                            <t t-esc="o.analysis_number or o.name or ''"/>
                        </span>
                    </td>
                </tr>

                <!-- Fila 3: Encabezados de columnas -->
                <tr style="background-color: #D9D9D9; font-weight: bold; text-align: center;">
                    <td style="border: 1px solid #4472C4; padding: 4px 6px; width: 9%;"># Muestra</td>
                    <td style="border: 1px solid #4472C4; padding: 4px 6px; width: 15%;"><t t-esc="o.anexo_col1_header or ''"/></td>
                    <td style="border: 1px solid #4472C4; padding: 4px 6px; width: 15%;"><t t-esc="o.anexo_col2_header or ''"/></td>
                    <td style="border: 1px solid #4472C4; padding: 4px 6px; width: 15%;"><t t-esc="o.anexo_col3_header or ''"/></td>
                    <td style="border: 1px solid #4472C4; padding: 4px 6px; width: 15%;"><t t-esc="o.anexo_col4_header or ''"/></td>
                    <td style="border: 1px solid #4472C4; padding: 4px 6px; width: 15%;"><t t-esc="o.anexo_col5_header or ''"/></td>
                    <td style="border: 1px solid #4472C4; padding: 4px 6px; width: 16%;"><t t-esc="o.anexo_col6_header or ''"/></td>
                </tr>

                <!-- Filas de datos -->
                <t t-foreach="o.anexo_line_ids" t-as="line">
                    <tr>
                        <td style="border: 1px solid #4472C4; padding: 4px 6px; text-align: center;"><t t-esc="line.muestra or ''"/></td>
                        <td style="border: 1px solid #4472C4; padding: 4px 6px;"><t t-esc="line.col1 or ''"/></td>
                        <td style="border: 1px solid #4472C4; padding: 4px 6px;"><t t-esc="line.col2 or ''"/></td>
                        <td style="border: 1px solid #4472C4; padding: 4px 6px;"><t t-esc="line.col3 or ''"/></td>
                        <td style="border: 1px solid #4472C4; padding: 4px 6px;"><t t-esc="line.col4 or ''"/></td>
                        <td style="border: 1px solid #4472C4; padding: 4px 6px;"><t t-esc="line.col5 or ''"/></td>
                        <td style="border: 1px solid #4472C4; padding: 4px 6px;"><t t-esc="line.col6 or ''"/></td>
                    </tr>
                </t>

            </table>

            <!-- ═══ FOTOGRAFÍAS ═══ -->
            <t t-if="o.anexo_photo_ids">
                <div style="margin-top: 30px;">
                    <div style="font-weight: bold; font-size: 11pt;
                                border-bottom: 2px solid #4472C4;
                                padding-bottom: 4px; margin-bottom: 12px;">
                        Fotografías:
                    </div>
                    <div style="display: flex; flex-wrap: wrap;
                                justify-content: center; gap: 12px;">
                        <t t-foreach="o.anexo_photo_ids" t-as="foto">
                            <t t-if="foto.datas">
                                <div style="text-align: center;">
                                    <img t-att-src="image_data_uri(foto.datas)"
                                         style="max-width: 190px; max-height: 190px;
                                                border: 1px solid #4472C4; display: block;"/>
                                    <span style="font-size: 9pt; color: #555;">
                                        <t t-esc="foto.name or ''"/>
                                    </span>
                                </div>
                            </t>
                        </t>
                    </div>
                </div>
            </t>

        </div>
    </template>

</odoo>
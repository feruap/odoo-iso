/** @odoo-module **/

import { registry } from "@web/core/registry";
import { useService } from "@web/core/utils/hooks";
const { Component, onWillStart, onWillUpdateProps } = owl;

export class VAMAMultiCheckWidget extends Component {
    setup() {
        this.orm = useService("orm");
        this.notification = useService("notification");
        
        onWillStart(async () => {
            await this._loadMapping();
            this._loadResults();
        });

        onWillUpdateProps(async (nextProps) => {
            if (nextProps.record.data.text_phrase_mapping !== this.props.record.data.text_phrase_mapping) {
                await this._loadMapping();
            }
            if (nextProps.record.data.multi_check_results_json !== this.props.record.data.multi_check_results_json) {
                this._loadResults();
            }
        });
    }

    async _loadMapping() {
        this.mapping = {};
        this.positions = [];
        try {
            const rawMapping = this.props.record.data.text_phrase_mapping;
            if (rawMapping) {
                this.mapping = JSON.parse(rawMapping);
                this.positions = this.mapping.positions || [];
            }
        } catch (e) {
            console.error("Error parsing mapping", e);
        }
    }

    _loadResults() {
        this.results = {};
        try {
            const rawResults = this.props.record.data.multi_check_results_json;
            if (rawResults) {
                this.results = JSON.parse(rawResults);
            } else {
                // Fallback to legacy pattern for backward compatibility
                const pattern = this.props.record.data.result_text_pattern || "";
                if (pattern) {
                    pattern.split(",").forEach((val, i) => {
                        this.results[i] = val.trim().toUpperCase();
                    });
                }
            }
        } catch (e) {
            console.error("Error loading results", e);
        }
    }

    getValue(index) {
        return this.results[index] || "";
    }

    async updateValue(index, value) {
        this.results[index] = value;
        const jsonResults = JSON.stringify(this.results);
        
        // Build legacy pattern (A,B,N) for compatibility
        const patternParts = [];
        for (let i = 0; i < this.positions.length; i++) {
            const val = this.results[i];
            const pType = this.positions[i].type || 'binary';
            if (pType === 'binary' || pType === 'select') {
                patternParts.push(val || "");
            } else {
                // For numeric, we might want to store A/B based on range evaluation in front-end?
                // No, let's just store the value and let the back-end handle evaluation.
                // Legacy pattern will just have the number.
                patternParts.push(val || "0");
            }
        }
        
        await this.props.record.update({
            multi_check_results_json: jsonResults,
            result_text_pattern: patternParts.join(",")
        });
    }
}

VAMAMultiCheckWidget.template = "amunet_quality.VAMAMultiCheckWidget";

registry.category("fields").add("vama_multi_check_widget", VAMAMultiCheckWidget);

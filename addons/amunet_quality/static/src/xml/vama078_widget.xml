<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="amunet_quality.VAMA078Widget" owl="1">
        <div class="o_vama078_widget">
            <h6 class="mb-3">VAMA-078: Multi-Visual Liofilizado (4 Características)</h6>
            
            <!-- Condición 1: Color -->
            <div class="card mb-2">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-6">
                            <label class="fw-bold mb-0">1. Color del Liofilizado</label>
                            <small class="text-muted d-block">Esperado: Blanco</small>
                        </div>
                        <div class="col-5">
                            <div class="btn-group d-flex" role="group">
                                <t t-foreach="colorOptions" t-as="option" t-key="option.value">
                                    <input type="radio"
                                           class="btn-check"
                                           t-att-name="'vama078_color_' + props.record.id"
                                           t-att-id="'color_' + option.value + '_' + props.record.id"
                                           t-att-value="option.value"
                                           t-att-checked="props.record.data.vama078_color === option.value"
                                           t-on-change="onColorChange"/>
                                    <label t-attf-class="btn btn-outline-secondary {{ props.record.data.vama078_color === option.value ? 'active' : '' }}"
                                           t-att-for="'color_' + option.value + '_' + props.record.id">
                                        <t t-esc="option.icon"/> <t t-esc="option.label"/>
                                    </label>
                                </t>
                            </div>
                        </div>
                        <div class="col-1 text-end">
                            <span t-if="colorPass" class="badge bg-success">✓</span>
                            <span t-elif="props.record.data.vama078_color" class="badge bg-warning">!</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Condición 2: Forma -->
            <div class="card mb-2">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-6">
                            <label class="fw-bold mb-0">2. Forma del Liofilizado</label>
                            <small class="text-muted d-block">Esperado: Compacto</small>
                        </div>
                        <div class="col-5">
                            <div class="btn-group d-flex" role="group">
                                <t t-foreach="formaOptions" t-as="option" t-key="option.value">
                                    <input type="radio"
                                           class="btn-check"
                                           t-att-name="'vama078_forma_' + props.record.id"
                                           t-att-id="'forma_' + option.value + '_' + props.record.id"
                                           t-att-value="option.value"
                                           t-att-checked="props.record.data.vama078_forma === option.value"
                                           t-on-change="onFormaChange"/>
                                    <label t-attf-class="btn btn-outline-secondary {{ props.record.data.vama078_forma === option.value ? 'active' : '' }}"
                                           t-att-for="'forma_' + option.value + '_' + props.record.id">
                                        <t t-esc="option.icon"/> <t t-esc="option.label"/>
                                    </label>
                                </t>
                            </div>
                        </div>
                        <div class="col-1 text-end">
                            <span t-if="formaPass" class="badge bg-success">✓</span>
                            <span t-elif="props.record.data.vama078_forma" class="badge bg-warning">!</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Condición 3: Textura -->
            <div class="card mb-2">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-6">
                            <label class="fw-bold mb-0">3. Textura del Liofilizado</label>
                            <small class="text-muted d-block">Esperado: Sin textura pegajosa</small>
                        </div>
                        <div class="col-5">
                            <div class="btn-group d-flex" role="group">
                                <t t-foreach="texturaOptions" t-as="option" t-key="option.value">
                                    <input type="radio"
                                           class="btn-check"
                                           t-att-name="'vama078_textura_' + props.record.id"
                                           t-att-id="'textura_' + option.value + '_' + props.record.id"
                                           t-att-value="option.value"
                                           t-att-checked="props.record.data.vama078_textura === option.value"
                                           t-on-change="onTexturaChange"/>
                                    <label t-attf-class="btn btn-outline-secondary {{ props.record.data.vama078_textura === option.value ? 'active' : '' }}"
                                           t-att-for="'textura_' + option.value + '_' + props.record.id">
                                        <t t-esc="option.icon"/> <t t-esc="option.label"/>
                                    </label>
                                </t>
                            </div>
                        </div>
                        <div class="col-1 text-end">
                            <span t-if="texturaPass" class="badge bg-success">✓</span>
                            <span t-elif="props.record.data.vama078_textura" class="badge bg-warning">!</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Condición 4: Humedad -->
            <div class="card mb-3">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-6">
                            <label class="fw-bold mb-0">4. Humedad Aparente</label>
                            <small class="text-muted d-block">Esperado: Sin humedad aparente</small>
                        </div>
                        <div class="col-5">
                            <div class="btn-group d-flex" role="group">
                                <t t-foreach="humedadOptions" t-as="option" t-key="option.value">
                                    <input type="radio"
                                           class="btn-check"
                                           t-att-name="'vama078_humedad_' + props.record.id"
                                           t-att-id="'humedad_' + option.value + '_' + props.record.id"
                                           t-att-value="option.value"
                                           t-att-checked="props.record.data.vama078_humedad === option.value"
                                           t-on-change="onHumedadChange"/>
                                    <label t-attf-class="btn btn-outline-secondary {{ props.record.data.vama078_humedad === option.value ? 'active' : '' }}"
                                           t-att-for="'humedad_' + option.value + '_' + props.record.id">
                                        <t t-esc="option.icon"/> <t t-esc="option.label"/>
                                    </label>
                                </t>
                            </div>
                        </div>
                        <div class="col-1 text-end">
                            <span t-if="humedadPass" class="badge bg-success">✓</span>
                            <span t-elif="props.record.data.vama078_humedad" class="badge bg-warning">!</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Resultado Generado -->
            <div class="alert alert-info" t-if="props.record.data.vama078_result_text">
                <strong>Resultado:</strong> <t t-esc="props.record.data.vama078_result_text"/>
            </div>

            <!-- Dictamen Final -->
            <div t-if="props.record.data.verdict and props.record.data.evaluation_type === 'vama_078'">
                <div t-attf-class="alert py-3 {{ props.record.data.verdict === 'pass' ? 'alert-success' : props.record.data.verdict === 'fail' ? 'alert-danger' : 'alert-warning' }}">
                    <h5 class="mb-0">
                        <i t-attf-class="fa me-2 {{ props.record.data.verdict === 'pass' ? 'fa-check-circle' : props.record.data.verdict === 'fail' ? 'fa-times-circle' : 'fa-clock-o' }}"/>
                        <strong t-if="props.record.data.verdict === 'pass'">✓ CUMPLE</strong>
                        <strong t-elif="props.record.data.verdict === 'fail'">✗ NO CUMPLE</strong>
                        <strong t-else="">⏳ PENDIENTE</strong>
                    </h5>
                </div>
            </div>
        </div>
    </t>
</templates>

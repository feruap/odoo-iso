<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- Float Field Template with Dynamic Placeholder -->
    <t t-name="amunet_quality.DynamicPlaceholderFloatField">
        <span t-if="props.readonly" t-esc="formattedValue" />
        <input
            t-else=""
            t-on-focusin="onFocusIn"
            t-on-focusout="onFocusOut"
            t-att-id="props.id"
            t-ref="numpadDecimal"
            t-att-type="props.inputType"
            inputmode="decimal"
            class="o_input"
            autocomplete="off"
            t-att-step="props.step"
            t-att-placeholder="props.placeholder" />
    </t>

    <!-- Html Field Template with Dynamic Placeholder -->
    <t t-name="amunet_quality.DynamicPlaceholderHtmlField">
        <t t-call="web.HtmlField" />
    </t>

</templates>

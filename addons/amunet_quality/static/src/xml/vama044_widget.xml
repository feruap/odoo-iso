<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="amunet_quality.VAMA044Widget" owl="1">
        <div class="o_vama044_widget">
            <h6 class="mb-3">VAMA-044: Funcionalidad de Tubo Colector (4 Condiciones)</h6>
            
            <!-- Condición 1: Número de Gotas -->
            <div class="card mb-2">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-6">
                            <label class="fw-bold mb-0">1. Número de Gotas</label>
                            <small class="text-muted d-block">Mínimo: <t t-esc="props.record.data.vama044_num_gotas_min || 5"/> gotas</small>
                        </div>
                        <div class="col-4">
                            <input type="number" 
                                   class="form-control" 
                                   t-att-value="props.record.data.vama044_num_gotas"
                                   t-on-change="onNumGotasChange"
                                   placeholder="Gotas"/>
                        </div>
                        <div class="col-2 text-end">
                            <span t-if="condition1Pass" class="badge bg-success">✓</span>
                            <span t-elif="props.record.data.vama044_num_gotas" class="badge bg-danger">✗</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Condición 2: Volumen de Gota -->
            <div class="card mb-2">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-6">
                            <label class="fw-bold mb-0">2. Volumen de Gota (µl)</label>
                            <small class="text-muted d-block">Rango: <t t-esc="props.record.data.vama044_vol_gota_min || 40"/> - <t t-esc="props.record.data.vama044_vol_gota_max || 50"/> µl</small>
                        </div>
                        <div class="col-4">
                            <input type="number" 
                                   step="0.01"
                                   class="form-control" 
                                   t-att-value="props.record.data.vama044_vol_gota"
                                   t-on-change="onVolGotaChange"
                                   placeholder="µl"/>
                        </div>
                        <div class="col-2 text-end">
                            <span t-if="condition2Pass" class="badge bg-success">✓</span>
                            <span t-elif="props.record.data.vama044_vol_gota" class="badge bg-danger">✗</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Condición 3: Unión Tapa-Tubo -->
            <div class="card mb-2">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-6">
                            <label class="fw-bold mb-0">3. Unión Tapa-Tubo</label>
                        </div>
                        <div class="col-4">
                            <select class="form-select"
                                    t-att-value="props.record.data.vama044_union"
                                    t-on-change="onUnionChange">
                                <option value="">-- Seleccione --</option>
                                <t t-foreach="unionOptions" t-as="option" t-key="option.value">
                                    <option t-att-value="option.value"
                                            t-att-selected="props.record.data.vama044_union === option.value">
                                        <t t-esc="option.label"/>
                                    </option>
                                </t>
                            </select>
                        </div>
                        <div class="col-2 text-end">
                            <span t-if="condition3Pass" class="badge bg-success">✓</span>
                            <span t-elif="props.record.data.vama044_union" class="badge bg-danger">✗</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Condición 4: Volumen de Llenado -->
            <div class="card mb-3">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-6">
                            <label class="fw-bold mb-0">4. Volumen de Llenado (µl)</label>
                            <small class="text-muted d-block">Rango: <t t-esc="props.record.data.vama044_vol_llenado_min || 1540"/> - <t t-esc="props.record.data.vama044_vol_llenado_max || 1560"/> µl</small>
                        </div>
                        <div class="col-4">
                            <input type="number" 
                                   step="0.01"
                                   class="form-control" 
                                   t-att-value="props.record.data.vama044_vol_llenado"
                                   t-on-change="onVolLlenadoChange"
                                   placeholder="µl"/>
                        </div>
                        <div class="col-2 text-end">
                            <span t-if="condition4Pass" class="badge bg-success">✓</span>
                            <span t-elif="props.record.data.vama044_vol_llenado" class="badge bg-danger">✗</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Resultado Generado -->
            <div class="alert alert-info" t-if="props.record.data.vama044_result_text">
                <strong>Resultado:</strong> <t t-esc="props.record.data.vama044_result_text"/>
            </div>

            <!-- Dictamen Final -->
            <div t-if="props.record.data.verdict and props.record.data.evaluation_type === 'vama_044'">
                <div t-attf-class="alert py-3 {{ props.record.data.verdict === 'pass' ? 'alert-success' : props.record.data.verdict === 'fail' ? 'alert-danger' : 'alert-warning' }}">
                    <h5 class="mb-0">
                        <i t-attf-class="fa me-2 {{ props.record.data.verdict === 'pass' ? 'fa-check-circle' : props.record.data.verdict === 'fail' ? 'fa-times-circle' : 'fa-clock-o' }}"/>
                        <strong t-if="props.record.data.verdict === 'pass'">✓ CUMPLE</strong>
                        <strong t-elif="props.record.data.verdict === 'fail'">✗ NO CUMPLE</strong>
                        <strong t-else="">⏳ PENDIENTE</strong>
                    </h5>
                </div>
            </div>
        </div>
    </t>
</templates>

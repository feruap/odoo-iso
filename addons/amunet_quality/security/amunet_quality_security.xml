<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Grupos de Seguridad - Control de Calidad Amunet
        Epic-029: Sistema de Control de Calidad
        T-029-16: Configurar grupos de seguridad
    -->

    <!-- Grupo: Usuario de QC (Analista) -->
    <record id="group_quality_user" model="res.groups">
        <field name="name">Calidad / Analista QC</field>
        <field name="implied_ids" eval="[(6, 0, [ref('base.group_user')])]"/>
        <field name="comment">
            Puede crear y editar controles de calidad.
            Puede registrar resultados de pruebas.
            Puede firmar en el campo "Realizó".
        </field>
    </record>

    <!-- Grupo: Supervisor de QC -->
    <record id="group_quality_supervisor" model="res.groups">
        <field name="name">Calidad / Supervisor QC</field>
        <field name="implied_ids" eval="[(6, 0, [ref('base.group_user')])]"/>
        <field name="comment">
            Todos los permisos del Analista.
            Puede firmar en el campo "Verificó".
        </field>
    </record>

    <!-- Grupo: Responsable Sanitario -->
    <record id="group_quality_sanitary" model="res.groups">
        <field name="name">Calidad / Responsable Sanitario</field>
        <field name="implied_ids" eval="[(6, 0, [ref('base.group_user')])]"/>
        <field name="comment">
            Todos los permisos del Supervisor.
            Puede firmar en el campo "Autorizó".
            Único que puede finalizar el análisis.
        </field>
    </record>

    <!-- Grupo: Manager de QC -->
    <record id="group_quality_manager" model="res.groups">
        <field name="name">Calidad / Manager QC</field>
        <field name="implied_ids" eval="[(6, 0, [ref('base.group_user')])]"/>
        <field name="comment">
            Acceso total al módulo de calidad.
            Puede configurar parámetros.
            Puede eliminar registros (con restricciones).
        </field>
    </record>

    <record id="rule_signature_pin_own_record" model="ir.rule">
        <field name="name">PIN de Firma: solo registro propio</field>
        <field name="model_id" ref="model_amunet_quality_signature_pin"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[
            (4, ref('base.group_user')),
            (4, ref('amunet_quality.group_quality_user')),
            (4, ref('amunet_quality.group_quality_supervisor')),
            (4, ref('amunet_quality.group_quality_sanitary'))
        ]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_signature_pin_manager_all_records" model="ir.rule">
        <field name="name">PIN de Firma: administracion calidad</field>
        <field name="model_id" ref="model_amunet_quality_signature_pin"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[
            (4, ref('amunet_quality.group_quality_manager')),
            (4, ref('base.group_system'))
        ]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

</odoo>

<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Vista del Wizard de Reanálisis -->
    <record id="view_amunet_quality_reanalysis_wizard_form" model="ir.ui.view">
        <field name="name">amunet.quality.reanalysis.wizard.form</field>
        <field name="model">amunet.quality.reanalysis.wizard</field>
        <field name="arch" type="xml">
            <form string="Crear Reanálisis">
                <group>
                    <group string="Análisis original">
                        <field name="quality_check_id" readonly="1"/>
                        <field name="original_analysis_number"/>
                        <field name="original_result" widget="badge"
                            decoration-success="original_result == 'pass'"
                            decoration-danger="original_result == 'fail'"
                            decoration-muted="original_result == 'pending'"/>
                    </group>
                    <group string="Producto">
                        <field name="product_id"/>
                        <field name="lot_id"/>
                        <field name="qty_available"/>
                    </group>
                </group>
                <group string="Configuración del reanálisis">
                    <group>
                        <label for="qty_reanalysis"/>
                        <div class="o_row">
                            <field name="qty_reanalysis"/>
                            <field name="reanalysis_uom_id" options="{'no_create': True}"/>
                        </div>
                    </group>
                </group>
                <group>
                    <field name="reason" placeholder="Explique el motivo del reanálisis..."/>
                </group>
                <footer>
                    <button name="action_create_reanalysis"
                            string="Crear reanálisis"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Acción del Wizard -->
    <record id="action_amunet_quality_reanalysis_wizard" model="ir.actions.act_window">
        <field name="name">Crear reanálisis</field>
        <field name="res_model">amunet.quality.reanalysis.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_amunet_quality_check"/>
        <field name="binding_view_types">form</field>
    </record>
</odoo>











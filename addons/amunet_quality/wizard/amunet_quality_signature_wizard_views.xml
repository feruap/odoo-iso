<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_amunet_quality_signature_wizard_form" model="ir.ui.view">
        <field name="name">amunet.quality.signature.wizard.form</field>
        <field name="model">amunet.quality.signature.wizard</field>
        <field name="arch" type="xml">
            <form string="Firma electronica nominal">
                <group>
                    <div class="alert alert-info" role="alert">
                        <strong>Firma nominal:</strong> Use su <strong>contrasena personal de Odoo</strong> o su <strong>PIN de firma</strong>.
                        <br/>
                        <small class="text-muted">La firma queda ligada a su usuario, fecha/hora y significado de firma. Debe contar con capacitacion vigente en el PNO aplicable.</small>
                    </div>
                    <group>
                        <field name="password" password="True" string="Contrasena personal o PIN"/>
                        <field name="signature_type" invisible="1"/>
                        <field name="check_ids" invisible="1"/>
                    </group>
                </group>
                <footer>
                    <button name="action_confirm_signature" string="Firmar" type="object" class="btn-primary" icon="fa-lock"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>

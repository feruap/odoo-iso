<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree view for signature permissions management -->
    <record id="view_users_tree_amunet_quality" model="ir.ui.view">
        <field name="name">res.users.tree.amunet.quality</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <list string="Usuarios - Permisos de Firma" editable="bottom">
                <field name="name" readonly="1"/>
                <field name="login" readonly="1"/>
                <field name="employee_code"/>
                <field name="in_group_quality_user" widget="boolean_toggle" readonly="0" force_save="1"/>
                <field name="in_group_quality_supervisor" widget="boolean_toggle" readonly="0" force_save="1"/>
                <field name="in_group_quality_sanitary" widget="boolean_toggle" readonly="0" force_save="1"/>
                <field name="in_group_quality_manager" widget="boolean_toggle" readonly="0" force_save="1"/>
            </list>
        </field>
    </record>

    <!-- Form view for signature permissions management -->
    <record id="view_users_form_amunet_quality" model="ir.ui.view">
        <field name="name">res.users.form.amunet.quality</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <form string="Permisos de Firma">
                <sheet>
                    <group>
                        <group string="Información del Usuario">
                            <field name="name"/>
                            <field name="login"/>
                            <field name="employee_code"/>
                        </group>
                        <group string="Permisos de Firma en Controles de Calidad">
                            <field name="in_group_quality_user"/>
                            <field name="in_group_quality_supervisor"/>
                            <field name="in_group_quality_sanitary"/>
                            <field name="in_group_quality_manager"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Descripción de Permisos">
                            <group>
                                <group>
                                    <span class="o_form_label fw-bold">Analista QC</span>
                                    <div>
                                        <p>• Puede crear y editar controles de calidad</p>
                                        <p>• Puede registrar resultados de pruebas</p>
                                        <p>• Puede firmar en el campo "Realizó"</p>
                                    </div>
                                </group>
                                <group>
                                    <span class="o_form_label fw-bold">Supervisor QC</span>
                                    <div>
                                        <p>• Todos los permisos del Analista</p>
                                        <p>• Puede firmar en el campo "Verificó"</p>
                                    </div>
                                </group>
                            </group>
                            <group>
                                <group>
                                    <span class="o_form_label fw-bold">Responsable Sanitario</span>
                                    <div>
                                        <p>• Todos los permisos del Supervisor</p>
                                        <p>• Puede firmar en el campo "Autorizó"</p>
                                        <p>• Único que puede finalizar el análisis</p>
                                    </div>
                                </group>
                                <group>
                                    <span class="o_form_label fw-bold">Manager QC</span>
                                    <div>
                                        <p>• Acceso total al módulo de calidad</p>
                                        <p>• Puede configurar parámetros</p>
                                        <p>• Puede eliminar registros (con restricciones)</p>
                                    </div>
                                </group>
                            </group>
                        </page>
                        <page string="Seguridad y Hardening">
                            <group string="Política de Contraseñas (21 CFR Part 11 / NOM-241)">
                                <field name="password_last_set"/>
                                <field name="password_expiration_date"/>
                                <field name="password_expired" widget="boolean_toggle"/>
                            </group>
                            <div class="alert alert-warning" role="alert" invisible="not password_expired">
                                <i class="fa fa-warning"/> <strong>¡ATENCIÓN!</strong> La contraseña de este usuario ha expirado y debe ser actualizada para cumplir con la NOM-241.
                            </div>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action for signature permissions menu -->
    <record id="action_res_users_quality" model="ir.actions.act_window">
        <field name="name">Permisos de Firma</field>
        <field name="res_model">res.users</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_users_tree_amunet_quality')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_users_form_amunet_quality')})]"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Gestionar permisos de firma para usuarios
            </p>
            <p>
                Configure el código de empleado y los grupos de calidad para cada usuario.
            </p>
            <p>
                <strong>Grupos disponibles:</strong>
            </p>
            <ul>
                <li><strong>Analista QC</strong>: Puede firmar "Realizó"</li>
                <li><strong>Supervisor QC</strong>: Puede firmar "Verificó"</li>
                <li><strong>Responsable Sanitario</strong>: Puede firmar "Autorizó" y finalizar</li>
                <li><strong>Manager QC</strong>: Acceso total y configuración</li>
            </ul>
        </field>
    </record>
</odoo>

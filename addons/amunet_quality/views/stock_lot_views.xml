<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!--
        Extensión del formulario de stock.lot para solicitar reanálisis desde Inventario.

        Agrega:
          - Botón de acción "Solicitar Reanálisis" en el header (visible cuando
            existe al menos un análisis completado para el lote).
          - Smart button "Controles QC" que abre la lista de análisis del lote
            (visible cuando quality_check_count > 0).
    -->
    <record id="view_lot_form_inherit_amunet_quality" model="ir.ui.view">
        <field name="name">stock.lot.form.inherit.amunet.quality</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.view_production_lot_form"/>
        <field name="arch" type="xml">

            <!-- Botón de reanálisis en el header del formulario -->
            <xpath expr="//sheet" position="before">
                <header>
                    <field name="can_request_reanalysis" invisible="1"/>
                    <field name="amunet_lot_release_state" invisible="1"/>
                    <button name="action_request_reanalysis"
                            string="Solicitar Reanálisis"
                            type="object"
                            class="btn-primary"
                            icon="fa-refresh"
                            invisible="not can_request_reanalysis"/>
                    <button name="action_open_lot_release_wizard"
                            string="Liberar lote"
                            type="object"
                            class="btn-primary"
                            icon="fa-lock"
                            groups="amunet_quality.group_quality_sanitary,amunet_quality.group_quality_manager,base.group_system"
                            invisible="amunet_lot_release_state == 'released'"/>
                </header>
            </xpath>

            <!-- Smart button: número de controles QC del lote -->
            <div name="button_box" position="inside">
                <field name="quality_check_count" invisible="1"/>
                <button name="action_view_quality_checks"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-flask"
                        invisible="quality_check_count == 0">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_value">
                            <field name="quality_check_count"/>
                        </span>
                        <span class="o_stat_text">Controles QC</span>
                    </div>
                </button>
            </div>

            <xpath expr="//sheet" position="inside">
                <group string="Liberación DHR" name="amunet_lot_release_group">
                    <group>
                        <field name="amunet_lot_release_state" readonly="1"
                               decoration-success="amunet_lot_release_state == 'released'"
                               decoration-warning="amunet_lot_release_state == 'pending'"/>
                        <field name="amunet_lot_release_quality_check_id" readonly="1"
                               invisible="amunet_lot_release_state != 'released'"/>
                        <field name="amunet_lot_released_by_id" readonly="1"
                               invisible="amunet_lot_release_state != 'released'"/>
                        <field name="amunet_lot_released_date" readonly="1"
                               invisible="amunet_lot_release_state != 'released'"/>
                    </group>
                    <group invisible="amunet_lot_release_state != 'released'">
                        <field name="amunet_lot_release_hash" readonly="1"/>
                        <field name="amunet_lot_release_notes" readonly="1"/>
                    </group>
                </group>
                <group string="Snapshot DHR inmutable"
                       invisible="amunet_lot_release_state != 'released'">
                    <field name="amunet_lot_release_snapshot" readonly="1" nolabel="1"/>
                </group>
            </xpath>

        </field>
    </record>
</odoo>

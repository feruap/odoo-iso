<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ACTION DEF -->
    <record id="amunet_quality_supplier_audit_action" model="ir.actions.act_window">
        <field name="name">Auditorías a Proveedores</field>
        <field name="res_model">amunet.quality.supplier.audit</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
          <p class="o_view_nocontent_smiling_face">
            Registrar nueva auditoría de proveedor
          </p>
        </field>
    </record>

    <!-- TREE VIEW -->
    <record id="view_amunet_quality_supplier_audit_tree" model="ir.ui.view">
        <field name="name">amunet.quality.supplier.audit.tree</field>
        <field name="model">amunet.quality.supplier.audit</field>
        <field name="arch" type="xml">
            <list string="Auditorías">
                <field name="name"/>
                <field name="audit_date"/>
                <field name="partner_id"/>
                <field name="auditor_id"/>
                <field name="result" widget="badge" decoration-success="result == 'pass'" decoration-warning="result == 'conditional'" decoration-danger="result == 'fail'"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'done'"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_amunet_quality_supplier_audit_form" model="ir.ui.view">
        <field name="name">amunet.quality.supplier.audit.form</field>
        <field name="model">amunet.quality.supplier.audit</field>
        <field name="arch" type="xml">
            <form string="Auditoría de Proveedor">
                <header>
                    <button name="action_confirm" string="Confirmar y Actualizar Proveedor" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id" readonly="state != 'draft'"/>
                            <field name="audit_date" readonly="state != 'draft'"/>
                            <field name="auditor_id" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="result" widget="radio" options="{'horizontal': true}" readonly="state != 'draft'"/>
                            <field name="report_file" filename="report_filename" readonly="state != 'draft'"/>
                            <field name="report_filename" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Observaciones">
                            <field name="notes" placeholder="Detalles de hallazgos..." readonly="state != 'draft'"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
</odoo>

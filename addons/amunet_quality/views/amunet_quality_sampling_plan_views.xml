<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_amunet_quality_sampling_plan_list" model="ir.ui.view">
        <field name="name">amunet.quality.sampling.plan.list</field>
        <field name="model">amunet.quality.sampling.plan</field>
        <field name="arch" type="xml">
            <list string="Planes de muestreo">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="family"/>
                <field name="stage"/>
                <field name="lot_min"/>
                <field name="lot_max"/>
                <field name="method"/>
                <field name="fixed_qty"/>
                <field name="min_qty"/>
                <field name="max_qty"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_amunet_quality_sampling_plan_form" model="ir.ui.view">
        <field name="name">amunet.quality.sampling.plan.form</field>
        <field name="model">amunet.quality.sampling.plan</field>
        <field name="arch" type="xml">
            <form string="Plan de muestreo">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="active"/>
                            <field name="sequence"/>
                            <field name="family"/>
                            <field name="stage"/>
                            <field name="procedure_id"/>
                        </group>
                        <group>
                            <field name="lot_min"/>
                            <field name="lot_max"/>
                            <field name="method"/>
                            <field name="fixed_qty"/>
                            <field name="percent"/>
                            <field name="min_qty"/>
                            <field name="max_qty"/>
                        </group>
                    </group>
                    <group string="Aplicabilidad">
                        <field name="product_ids" widget="many2many_tags"/>
                        <field name="categ_ids" widget="many2many_tags"/>
                    </group>
                    <group string="Criterios Ac/Re">
                        <group>
                            <field name="critical_accept"/>
                            <field name="critical_reject"/>
                        </group>
                        <group>
                            <field name="major_accept"/>
                            <field name="major_reject"/>
                        </group>
                        <group>
                            <field name="minor_accept"/>
                            <field name="minor_reject"/>
                        </group>
                    </group>
                    <group string="Justificacion">
                        <field name="functional_sample_note"/>
                        <field name="regulatory_basis"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_amunet_quality_sampling_plan" model="ir.actions.act_window">
        <field name="name">Planes de muestreo</field>
        <field name="res_model">amunet.quality.sampling.plan</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- SEARCH VIEW -->
    <record id="view_amunet_quality_procedure_search" model="ir.ui.view">
        <field name="name">amunet.quality.procedure.search</field>
        <field name="model">amunet.quality.procedure</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="product_ids"/>
                <filter name="filter_active" string="Vigentes" domain="[('active', '=', True)]"/>
                <filter name="filter_archived" string="Archivados" domain="[('active', '=', False)]"/>
                <filter name="group_code" string="Código de Documento" context="{'group_by': 'code'}"/>
            </search>
        </field>
    </record>

    <!-- LIST VIEW -->
    <record id="view_amunet_quality_procedure_list" model="ir.ui.view">
        <field name="name">amunet.quality.procedure.list</field>
        <field name="model">amunet.quality.procedure</field>
        <field name="arch" type="xml">
            <list string="Procedimientos (SOPs)">
                <field name="code"/>
                <field name="name"/>
                <field name="version"/>
                <field name="active" widget="boolean_toggle"/>
                <field name="create_date"/>
                <field name="write_date"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_amunet_quality_procedure_form" model="ir.ui.view">
        <field name="name">amunet.quality.procedure.form</field>
        <field name="model">amunet.quality.procedure</field>
        <field name="arch" type="xml">
            <form string="Procedimiento (SOP)">
                <header>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="Ej: Instrucción de Inspección de Cajas"/></h1>
                        <h3>
                            <span class="oe_read_only">Código: </span>
                            <field name="code" placeholder="SOP-001" class="oe_inline"/>
                            <span class="oe_read_only"> | v</span>
                            <field name="version" class="oe_inline"/>
                        </h3>
                    </div>
                    <group>
                        <group>
                            <field name="document_file" filename="document_filename" widget="binary"/>
                            <field name="document_filename" invisible="1"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="product_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_amunet_quality_procedure" model="ir.actions.act_window">
        <field name="name">Control de Documentos (SOPs)</field>
        <field name="res_model">amunet.quality.procedure</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Cargar un nuevo Procedimiento Operativo (SOP)
            </p>
            <p>
                Gestione los documentos controlados (ISO 13485). 
                Al cargar una nueva versión con el mismo código, la anterior se archivará automáticamente.
            </p>
        </field>
    </record>
</odoo>

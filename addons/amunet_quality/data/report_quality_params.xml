<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Deshabilitar compresión de imágenes en reportes para mantener calidad original -->
        <record id="report_url_compression" model="ir.config_parameter">
            <field name="key">report.url_compression</field>
            <field name="value">False</field>
        </record>

        <!-- Establecer calidad máxima para wkhtmltopdf -->
        <record id="wkhtmltopdf_image_quality" model="ir.config_parameter">
            <field name="key">wkhtmltopdf.image_quality</field>
            <field name="value">100</field>
        </record>
    </data>
</odoo>

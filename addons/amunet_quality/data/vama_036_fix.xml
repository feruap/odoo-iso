<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- ======================================================== -->
        <!-- VAMA-036: Volumen de liofilizado -->
        <!-- CORRECCIÓN: 3 especificaciones con sus propios sistemas de validación -->
        <!-- ======================================================== -->
        
        <!-- Parámetro VAMA-036 -->
        <record id="param_vama_036" model="amunet.quality.check.parameter">
            <field name="code">VAMA-036</field>
            <field name="name">Volumen de liofilizado</field>
        </record>
        
        <!-- Especificación 1: Color del liofilizado (Selección binaria) -->
        <record id="spec_vama_036_01" model="amunet.quality.check.parameter.specification">
            <field name="parameter_id" ref="param_vama_036"/>
            <field name="name">Color del liofilizado</field>
            <field name="sequence">1</field>
            <field name="evaluation_type">binary_selection</field>
            <field name="acceptance_criteria">Blanco</field>
            <field name="binary_prefix"></field>
            <field name="binary_suffix"></field>
            <field name="binary_expected_option">with_prefix</field>
            <field name="binary_option_pass">Blanco</field>
            <field name="binary_option_fail">Amarillo</field>
        </record>
        
        <!-- Especificación 2: Forma del liofilizado (Selección binaria) -->
        <record id="spec_vama_036_02" model="amunet.quality.check.parameter.specification">
            <field name="parameter_id" ref="param_vama_036"/>
            <field name="name">Forma del liofilizado</field>
            <field name="sequence">2</field>
            <field name="evaluation_type">binary_selection</field>
            <field name="acceptance_criteria">Compacto</field>
            <field name="binary_prefix"></field>
            <field name="binary_suffix"></field>
            <field name="binary_expected_option">with_prefix</field>
            <field name="binary_option_pass">Compacto</field>
            <field name="binary_option_fail">Deformado</field>
        </record>
        
        <!-- Especificación 3: Volumen de liofilizado (Rango numérico) -->
        <record id="spec_vama_036_03" model="amunet.quality.check.parameter.specification">
            <field name="parameter_id" ref="param_vama_036"/>
            <field name="name">Volumen de liofilizado</field>
            <field name="sequence">3</field>
            <field name="evaluation_type">numeric_range</field>
            <field name="acceptance_criteria">≥ 0.5 cm de altura</field>
        </record>
        
    </data>
</odoo>

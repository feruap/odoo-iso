<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Secuencias para Control de Calidad
        Epic-029: Sistema de Control de Calidad
    -->

    <!-- Secuencia para nombre interno de QC -->
    <record id="sequence_quality_check" model="ir.sequence">
        <field name="name">Control de Calidad Amunet</field>
        <field name="code">amunet.quality.check</field>
        <field name="prefix">QC/%(year)s/</field>
        <field name="padding">5</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
        <field name="company_id" eval="False"/>
    </record>

</odoo>











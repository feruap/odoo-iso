<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_woo_sales_trend_search" model="ir.ui.view">
        <field name="name">amunet.woo.sales.trend.search</field>
        <field name="model">amunet.woo.sales.trend</field>
        <field name="arch" type="xml">
            <search string="Tendencia WooCommerce">
                <field name="woo_sku"/>
                <field name="product_tmpl_id"/>
                <field name="presentation_id"/>
                <filter name="group_product" string="Producto" context="{'group_by': 'product_tmpl_id'}"/>
                <filter name="group_presentation" string="Presentacion" context="{'group_by': 'presentation_id'}"/>
                <filter name="group_month" string="Mes" context="{'group_by': 'sale_date:month'}"/>
            </search>
        </field>
    </record>

    <record id="view_woo_sales_trend_list" model="ir.ui.view">
        <field name="name">amunet.woo.sales.trend.list</field>
        <field name="model">amunet.woo.sales.trend</field>
        <field name="arch" type="xml">
            <list string="Tendencia WooCommerce">
                <field name="sale_date"/>
                <field name="product_tmpl_id"/>
                <field name="presentation_id"/>
                <field name="woo_sku"/>
                <field name="box_qty"/>
                <field name="package_qty"/>
                <field name="piece_qty"/>
                <field name="order_status"/>
            </list>
        </field>
    </record>

    <record id="view_woo_sales_trend_form" model="ir.ui.view">
        <field name="name">amunet.woo.sales.trend.form</field>
        <field name="model">amunet.woo.sales.trend</field>
        <field name="arch" type="xml">
            <form string="Venta WooCommerce">
                <sheet>
                    <group>
                        <group>
                            <field name="sale_date"/>
                            <field name="source"/>
                            <field name="order_status"/>
                            <field name="woo_order_id"/>
                        </group>
                        <group>
                            <field name="product_tmpl_id"/>
                            <field name="product_id"/>
                            <field name="presentation_id"/>
                        </group>
                    </group>
                    <group string="WooCommerce">
                        <field name="woo_product_id"/>
                        <field name="woo_variation_id"/>
                        <field name="woo_sku"/>
                        <field name="woo_name"/>
                    </group>
                    <group string="Cantidades">
                        <field name="box_qty"/>
                        <field name="package_qty"/>
                        <field name="piece_qty"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_woo_sales_trend" model="ir.actions.act_window">
        <field name="name">Tendencia WooCommerce</field>
        <field name="res_model">amunet.woo.sales.trend</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_woo_sales_trend_search"/>
    </record>
</odoo>

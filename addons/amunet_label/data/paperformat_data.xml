<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!--
            Formato de papel Tabloid 11x17" (gran tabloide).
            Hoja fisica: 27.94 x 43.18 cm.
            Area imprimible que respeta la impresora: 27 x 42 cm.
            Margenes: 4.7mm cada lado horizontal, 5.9mm arriba y 11.8mm
            abajo aprox., para no rebasar la zona de impresion segura.

            wkhtmltopdf usa los margenes en mm.
        -->
        <record id="paperformat_tabloid_label" model="report.paperformat">
            <field name="name">Amunet Tabloid 11x17 etiqueta</field>
            <field name="format">custom</field>
            <field name="page_height">432</field>
            <field name="page_width">279</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">6</field>
            <field name="margin_bottom">12</field>
            <field name="margin_left">5</field>
            <field name="margin_right">5</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">0</field>
            <field name="dpi">90</field>
        </record>

    </data>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Grupo: Solicitante de Material -->
        <record id="group_material_requester" model="res.groups">
            <field name="name">Solicitudes de Material / Solicitante</field>
            <field name="implied_ids" eval="[(6, 0, [ref('base.group_user')])]"/>
            <field name="comment">
                Crea y envia solicitudes de material.
                Ve solo las solicitudes propias.
            </field>
        </record>

        <!-- Grupo: Almacen (surte y entrega) -->
        <record id="group_material_warehouse" model="res.groups">
            <field name="name">Solicitudes de Material / Almacen</field>
            <field name="implied_ids" eval="[(6, 0, [ref('group_material_requester'), ref('stock.group_stock_user')])]"/>
            <field name="comment">
                Recibe solicitudes, asigna lotes y confirma entregas.
                Ve todas las solicitudes.
            </field>
        </record>

        <!-- Grupo: Administrador del modulo -->
        <record id="group_material_manager" model="res.groups">
            <field name="name">Solicitudes de Material / Administrador</field>
            <field name="implied_ids" eval="[(6, 0, [ref('group_material_warehouse')])]"/>
            <field name="comment">
                Acceso total: cancela, regresa a borrador, ve todo.
            </field>
        </record>

        <!--
            Hacer que cualquier usuario interno (base.group_user, "Rol /
            Miembro") sea automaticamente Solicitante de Material. Asi
            todos los empleados activos y los nuevos que se den de alta
            quedan habilitados para crear sus propias solicitudes sin
            necesidad de asignacion manual.

            (4, ref) agrega al implied_ids existente del grupo
            base.group_user sin reemplazar nada (no rompe otras apps).
        -->
        <record id="base.group_user" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('amunet_material_request.group_material_requester'))]"/>
        </record>

    </data>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- El solicitante solo ve sus propias solicitudes -->
        <record id="material_request_rule_requester_own" model="ir.rule">
            <field name="name">Solicitudes: solicitante ve solo las propias</field>
            <field name="model_id" ref="model_amunet_material_request"/>
            <field name="domain_force">[('requester_id','=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_material_requester'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Almacen ve todas -->
        <record id="material_request_rule_warehouse_all" model="ir.rule">
            <field name="name">Solicitudes: almacen ve todas</field>
            <field name="model_id" ref="model_amunet_material_request"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(4, ref('group_material_warehouse'))]"/>
        </record>

        <!-- Manager ve todas -->
        <record id="material_request_rule_manager_all" model="ir.rule">
            <field name="name">Solicitudes: manager ve todas</field>
            <field name="model_id" ref="model_amunet_material_request"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(4, ref('group_material_manager'))]"/>
        </record>

        <!-- Lineas: replicar acceso del padre -->
        <record id="material_request_line_rule_requester_own" model="ir.rule">
            <field name="name">Lineas: solicitante ve solo de sus solicitudes</field>
            <field name="model_id" ref="model_amunet_material_request_line"/>
            <field name="domain_force">[('request_id.requester_id','=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_material_requester'))]"/>
        </record>

        <record id="material_request_line_rule_warehouse_all" model="ir.rule">
            <field name="name">Lineas: almacen ve todas</field>
            <field name="model_id" ref="model_amunet_material_request_line"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(4, ref('group_material_warehouse'))]"/>
        </record>

    </data>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_material_request_doc">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Solicitud de Material</h2>
                        <h3><span t-field="o.name"/></h3>

                        <div class="row mt32 mb16">
                            <div class="col-6">
                                <strong>Solicitante:</strong>
                                <p><span t-field="o.requester_id"/></p>
                                <strong>Area:</strong>
                                <p><span t-field="o.department_id"/></p>
                                <strong>Almacen origen:</strong>
                                <p><span t-field="o.warehouse_id"/></p>
                            </div>
                            <div class="col-6">
                                <strong>Fecha solicitud:</strong>
                                <p><span t-field="o.request_date"/></p>
                                <strong>Fecha requerida:</strong>
                                <p><span t-field="o.required_date"/></p>
                                <strong>Estado:</strong>
                                <p><span t-field="o.state"/></p>
                                <strong>Transferencia:</strong>
                                <p><span t-field="o.picking_id.name"/></p>
                            </div>
                        </div>

                        <table class="table table-sm table-bordered">
                            <thead>
                                <tr>
                                    <th>Producto</th>
                                    <th class="text-end">Cantidad solicitada</th>
                                    <th class="text-end">Cantidad surtida</th>
                                    <th>UdM</th>
                                    <th>Lote</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="o.line_ids" t-as="line">
                                    <td><span t-field="line.product_id"/></td>
                                    <td class="text-end"><span t-field="line.qty_requested"/></td>
                                    <td class="text-end"><span t-field="line.qty_supplied"/></td>
                                    <td><span t-field="line.uom_id"/></td>
                                    <td><span t-field="line.lot_id"/></td>
                                </tr>
                            </tbody>
                        </table>

                        <div t-if="o.note" class="mt16">
                            <strong>Notas:</strong>
                            <p><span t-field="o.note"/></p>
                        </div>

                        <div class="row mt32">
                            <div class="col-6">
                                <strong>Firma Solicitante</strong>
                                <p>
                                    <span t-field="o.user_requested_id"/><br/>
                                    <small><span t-field="o.requested_signature_date"/></small>
                                </p>
                                <hr/>
                            </div>
                            <div class="col-6">
                                <strong>Firma Almacen</strong>
                                <p>
                                    <span t-field="o.user_dispatched_id"/><br/>
                                    <small><span t-field="o.dispatched_signature_date"/></small>
                                </p>
                                <hr/>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Agregar el campo de codigo en el form de Departamento -->
    <record id="view_hr_department_form_material_code" model="ir.ui.view">
        <field name="name">hr.department.form.material.code</field>
        <field name="model">hr.department</field>
        <field name="inherit_id" ref="hr.view_department_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='parent_id']" position="after">
                <field name="material_request_code"
                       placeholder="PRO, CAL, MAN..."
                       string="Codigo Solicitudes Material"/>
            </xpath>
        </field>
    </record>

    <!-- Mostrar el codigo en la lista de departamentos -->
    <record id="view_hr_department_tree_material_code" model="ir.ui.view">
        <field name="name">hr.department.tree.material.code</field>
        <field name="model">hr.department</field>
        <field name="inherit_id" ref="hr.view_department_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="material_request_code"
                       string="Codigo Solicit. Material"
                       optional="show"/>
            </xpath>
        </field>
    </record>

</odoo>

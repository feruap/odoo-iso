<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Menu raiz top-level: Solicitudes de Material aparece como su
        propia aplicacion en el AppSwitcher de Odoo, al mismo nivel
        que Inventario / Compras / Empleados. El solicitante no
        necesita acceso al modulo Inventario para pedir material.
    -->
    <menuitem id="menu_amunet_material_request_root"
              name="Solicitudes de Material"
              sequence="80"
              web_icon="amunet_material_request,static/description/icon.png"
              groups="amunet_material_request.group_material_requester,amunet_material_request.group_material_warehouse,amunet_material_request.group_material_manager"/>

    <!--
        Menu hijo principal: la lista de solicitudes.
    -->
    <menuitem id="menu_amunet_material_request_main"
              name="Solicitudes"
              parent="menu_amunet_material_request_root"
              action="action_amunet_material_request"
              sequence="10"/>

</odoo>

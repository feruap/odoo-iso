<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!--
            Ubicacion virtual tipo "production" para que el material entregado
            no quede contabilizado como stock real (se considera consumido).
            La trazabilidad queda en el stock.move + lote + firmas.
        -->
        <record id="location_consumption_requests" model="stock.location">
            <field name="name">Consumo - Solicitudes de Material</field>
            <field name="usage">production</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>

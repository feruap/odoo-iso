<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!--
            Cron diario: revisa cursos en Borrador cuya fecha de inicio
            es exactamente 7 dias en el futuro. Si encuentra alguno
            crea una actividad al grupo de RH y manda recordatorio al
            ponente.
        -->
        <record id="ir_cron_training_alerta_7_dias" model="ir.cron">
            <field name="name">Capacitaciones: alerta 7 dias antes</field>
            <field name="model_id" ref="model_hr_training_course"/>
            <field name="state">code</field>
            <field name="code">model._cron_alerta_7_dias()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

    </data>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Form View de Calibración -->
        <record id="view_amunet_equipment_calibration_form" model="ir.ui.view">
            <field name="name">amunet.equipment.calibration.form</field>
            <field name="model">amunet.equipment.calibration</field>
            <field name="arch" type="xml">
                <form string="Certificado de Calibración">
                    <header>
                        <button name="action_approve" type="object" string="Aprobar" class="oe_highlight" invisible="state != 'draft'" groups="amunet_equipment_calibration.group_equipment_manager"/>
                        <button name="action_cancel" type="object" string="Cancelar" invisible="state not in ('draft', 'done')" groups="amunet_equipment_calibration.group_equipment_manager"/>
                        <button name="action_draft" type="object" string="Volver a Borrador" invisible="state != 'cancelled'" groups="amunet_equipment_calibration.group_equipment_manager"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,done,cancelled"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="equipment_id" options="{'no_create': True}" readonly="state != 'draft'"/>
                                <field name="lab_name" readonly="state != 'draft'"/>
                            </group>
                            <group>
                                <field name="calibration_date" readonly="state != 'draft'"/>
                                <field name="expiration_date" readonly="state != 'draft'"/>
                            </group>
                        </group>
                        <group name="certificate">
                            <field name="certificate_file" filename="certificate_filename" readonly="state != 'draft'"/>
                            <field name="certificate_filename" invisible="1"/>
                        </group>
                        <group name="notes" string="Observaciones">
                            <field name="notes" nolabel="1" readonly="state != 'draft'"/>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>
    </data>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Grupo para Gestionar Equipos -->
        <record id="group_equipment_manager" model="res.groups">
            <field name="name">Gestor de Equipos / Metrología</field>
        </record>
        <record id="group_maintenance_technician" model="res.groups">
            <field name="name">Mantenimiento / Tecnico</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">
                Ejecuta mantenimientos de equipos desde Mi mantenimiento. No administra calibraciones FVA.
            </field>
        </record>
    </data>
</odoo>

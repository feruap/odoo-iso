<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- Heredar template OWL del reporte de trazabilidad -->
    <t t-name="stock.TraceabilityReport" t-inherit="stock.TraceabilityReport" t-inherit-mode="extension">
        <!-- Reemplazar encabezados de la tabla -->
        <xpath expr="//thead/tr[@class='o_report_header']" position="replace">
            <tr class="o_report_header">
                <th class="o_report_line_header">Reference</th>
                <th class="o_report_line_header">Product</th>
                <th class="o_report_line_header">Date</th>
                <th class="o_report_line_header">Número de serie/lote de fábrica</th>
                <th class="o_report_line_header">Número de serie/lote Amunet</th>
                <th class="o_report_line_header">From</th>
                <th class="o_report_line_header">To</th>
                <th class="o_report_line_header">Quantity</th>
            </tr>
        </xpath>
    </t>

</templates>

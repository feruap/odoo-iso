<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron para reiniciar secuencias mensualmente -->
        <record id="ir_cron_reset_amunet_lot_sequences" model="ir.cron">
            <field name="name">Amunet Lot: Reinicio Mensual de Secuencias</field>
            <field name="model_id" ref="product.model_product_template"/>
            <field name="state">code</field>
            <field name="code">model._cron_reset_amunet_lot_sequences_monthly()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
        </record>
    </data>
</odoo>


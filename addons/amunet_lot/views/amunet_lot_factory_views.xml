    <!-- Acción de ventana -->
    <record id="action_amunet_lot_factory" model="ir.actions.act_window">
        <field name="name">Números de serie/lote de fábrica</field>
        <field name="res_model">amunet.lot.factory</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crear un nuevo número de serie/lote de fábrica
            </p>
            <p>
                Los números de serie/lote fábrica permiten agrupar múltiples lotes Amunet bajo un mismo número de lote del fabricante.
            </p>
        </field>
    </record>

    <!-- Menú: Número de serie/lote de fábrica -->
    <menuitem 
        id="menu_amunet_lot_factory"
        name="Números de serie/lote de fábrica"
        parent="stock.menu_stock_inventory_control"
        action="action_amunet_lot_factory"
        groups="stock.group_production_lot"
        sequence="102"/>

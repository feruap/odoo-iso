<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista Formulario -->
    <record id="view_amunet_lot_factory_form" model="ir.ui.view">
        <field name="name">amunet.lot.factory.form</field>
        <field name="model">amunet.lot.factory</field>
        <field name="arch" type="xml">
            <form string="Lote de Fábrica">
                <sheet>
                    <!-- <div class="oe_button_box" name="button_box">
                        <button name="action_view_lots"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-cubes"
                                invisible="lot_count == 0">
                            <field name="lot_count" widget="statinfo" string="Lotes Amunet"/>
                        </button>
                    </div> -->

                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="Ej: FAB-2024-001"/>
                        </h1>
                    </div>

                    <group>
                        <field name="ref" placeholder="Referencia opcional"/>
                    </group>

                    <notebook>
                        <page string="Números de serie/lote Amunet relacionados" name="lot_ids">
                            <field name="lot_ids"
                                   readonly="1"
                                   nolabel="1"
                                   context="{'default_factory_lot_id': id}">
                                <list string="Lotes Amunet" create="0" delete="0">
                                    <field name="name" string="Número de lote Amunet"/>
                                    <field name="product_id" string="Producto"/>
                                    <field name="ref"  optional="hide"/>
                                    <field name="product_qty" string="Cantidad" optional="show"/>
                                    <field name="create_date" string="Fecha de creación" optional="show"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Vista Tree -->
    <record id="view_amunet_lot_factory_tree" model="ir.ui.view">
        <field name="name">amunet.lot.factory.tree</field>
        <field name="model">amunet.lot.factory</field>
        <field name="arch" type="xml">
            <list string="Números de serie/lote de fábrica">
                <field name="name" string="Número de serie/lote de fábrica"/>
                <field name="ref" optional="show"/>
                <field name="lot_count" string="Cantidad de lotes Amunet"/>
                <field name="create_date" string="Fecha creación" optional="hide"/>
            </list>
        </field>
    </record>


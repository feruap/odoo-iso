<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Extensión del formulario de almacén: Tab "Usuarios con Acceso" -->
    <record id="view_warehouse_form_user_access" model="ir.ui.view">
        <field name="name">stock.warehouse.form.user.access</field>
        <field name="model">stock.warehouse</field>
        <field name="inherit_id" ref="stock.view_warehouse"/>
        <field name="arch" type="xml">

            <!-- Agregar tab después de "Configuración Técnica" -->
            <xpath expr="//notebook" position="inside">
                <page name="user_access" string="Usuarios con acceso"
                      groups="base.group_system">

                    <group>
                        <group>
                            <field name="allowed_user_count" string="Usuarios con acceso"/>
                        </group>
                        <group>
                            <button name="action_view_user_accesses"
                                    type="object"
                                    string="Gestionar accesos"
                                    class="btn-primary"
                                    icon="fa-users"/>
                        </group>
                    </group>

                    <group string="Configuración de control de acceso de usuarios" col="1">
                        <field name="user_access_ids" nolabel="1" context="{'default_warehouse_id': id}">
                            <list editable="bottom">
                                <field name="user_id"
                                       options="{'no_create': True, 'no_create_edit': True}"/>
                                <field name="access_type" widget="badge"
                                       decoration-success="access_type == 'full'"
                                       decoration-warning="access_type == 'restricted'"/>
                                <field name="operation_type_ids" widget="many2many_tags"
                                       invisible="access_type == 'full'"
                                       options="{'no_create': True, 'no_create_edit': True}"/>
                                <field name="active" widget="boolean_toggle"/>
                            </list>
                        </field>
                    </group>

                    <group string="Usuarios permitidos (vista rápida)" invisible="allowed_user_count == 0">
                        <field name="allowed_user_ids" widget="many2many_tags" readonly="1" nolabel="1"/>
                    </group>

                    <div class="alert alert-info" role="alert" invisible="allowed_user_count > 0">
                        <p><strong>Sin accesos configurados</strong></p>
                        <p>Ningún usuario tiene acceso configurado a este almacén.
                           Los administradores del sistema tienen acceso automático a todos los almacenes.</p>
                    </div>

                </page>
            </xpath>

        </field>
    </record>

    <!-- Vista de Lista de Almacenes con columna de usuarios -->
    <record id="view_warehouse_tree_user_access" model="ir.ui.view">
        <field name="name">stock.warehouse.tree.user.access</field>
        <field name="model">stock.warehouse</field>
        <field name="inherit_id" ref="stock.view_warehouse_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="allowed_user_count" string="Usuarios" optional="hide"/>
            </xpath>
        </field>
    </record>

</odoo>

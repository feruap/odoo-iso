<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vista de Lista: Matriz de Accesos -->
    <record id="view_warehouse_access_list" model="ir.ui.view">
        <field name="name">amunet.warehouse.access.list</field>
        <field name="model">amunet.warehouse.access</field>
        <field name="arch" type="xml">
            <list string="Control de accesos a almacenes"
                  create="true" edit="true" delete="true"
                  decoration-muted="not active"
                  decoration-success="access_type == 'full' and active"
                  decoration-warning="access_type == 'restricted' and active">

                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="warehouse_id"/>
                <field name="access_type" widget="badge"
                       decoration-success="access_type == 'full'"
                       decoration-warning="access_type == 'restricted'"/>
                <field name="operation_type_ids" widget="many2many_tags"
                       optional="show"/>
                <field name="rule_count" string="Reglas" optional="hide"/>
                <field name="active" widget="boolean_toggle"/>

                <button name="action_view_rules"
                        type="object"
                        icon="fa-list"
                        title="Ver reglas generadas"
                        invisible="rule_count == 0"/>

            </list>
        </field>
    </record>

    <!-- Vista de Formulario: Configuración de Acceso Individual -->
    <record id="view_warehouse_access_form" model="ir.ui.view">
        <field name="name">amunet.warehouse.access.form</field>
        <field name="model">amunet.warehouse.access</field>
        <field name="arch" type="xml">
            <form string="Configuración de control de acceso a almacén">

                <header>
                    <button name="action_view_rules"
                            type="object"
                            string="Ver reglas generadas"
                            class="btn-primary"
                            invisible="rule_count == 0"/>
                    <field name="active" widget="boolean_button"
                           options="{'terminology': 'active'}"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group name="user_warehouse" string="Usuario y almacén">
                            <field name="user_id"
                                   options="{'no_create': True, 'no_create_edit': True}"
                                   required="1"/>
                            <field name="warehouse_id"
                                   options="{'no_create': True, 'no_create_edit': True}"
                                   required="1"/>
                        </group>

                        <group name="access_config" string="Configuración de acceso">
                            <field name="access_type" widget="radio" required="1"/>
                            <field name="rule_count" string="Reglas generadas"/>
                        </group>
                    </group>

                    <notebook>
                        <page name="operations" string="Operaciones permitidas"
                              invisible="access_type == 'full'">
                            <field name="operation_type_ids" nolabel="1"
                                   context="{'default_warehouse_id': warehouse_id}"
                                   options="{'no_create': True, 'no_create_edit': True}">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="sequence" optional="hide"/>
                                    <field name="code" optional="hide"/>
                                    <field name="warehouse_id" invisible="1"/>
                                </list>
                            </field>

                            <div class="alert alert-warning" role="alert"
                                 invisible="operation_type_ids">
                                <p><strong>Atención:</strong> Debe seleccionar al menos una operación permitida.</p>
                                <p>Si desea dar acceso completo al almacén, cambie el "Tipo de acceso" a "Acceso completo".</p>
                            </div>
                        </page>

                        <page name="full_access_info" string="Información de acceso completo"
                              invisible="access_type == 'restricted'">
                            <div class="alert alert-success" role="alert">
                                <h4><i class="fa fa-check-circle"/> Acceso completo configurado</h4>
                                <p>El usuario <strong><field name="user_id" readonly="1" nolabel="1" class="oe_inline"/></strong>
                                   tiene acceso completo al almacén <strong><field name="warehouse_id" readonly="1" nolabel="1" class="oe_inline"/></strong>.</p>
                                <p>Podrá realizar todas las operaciones disponibles:</p>
                                <ul>
                                    <li>Recepciones</li>
                                    <li>Entregas</li>
                                    <li>Transferencias iternas</li>
                                    <li>Ajustes de inventario</li>
                                    <li>Cualquier otra operación del almacén</li>
                                </ul>
                            </div>
                        </page>

                        <page name="rules" string="Reglas generadas" invisible="rule_count == 0">
                            <field name="rule_ids" nolabel="1" readonly="1">
                                <list>
                                    <field name="model_name"/>
                                    <field name="domain_force" widget="text"/>
                                    <field name="active" widget="boolean_toggle"/>
                                    <button name="action_view_odoo_rule"
                                            type="object"
                                            icon="fa-external-link"
                                            title="Ver regla de Odoo"/>
                                </list>
                            </field>
                        </page>
                    </notebook>

                </sheet>

                <chatter/>

            </form>
        </field>
    </record>

    <!-- Vista de Búsqueda: Filtros y Agrupaciones -->
    <record id="view_warehouse_access_search" model="ir.ui.view">
        <field name="name">amunet.warehouse.access.search</field>
        <field name="model">amunet.warehouse.access</field>
        <field name="arch" type="xml">
            <search>
                <field name="user_id"/>
                <field name="warehouse_id"/>
                <field name="name"/>
                <filter name="filter_active" string="Activos" domain="[('active', '=', True)]"/>
                <filter name="filter_inactive" string="Inactivos" domain="[('active', '=', False)]"/>
                <separator/>
                <filter name="filter_full_access" string="Acceso completo" domain="[('access_type', '=', 'full')]"/>
                <filter name="filter_restricted_access" string="Acceso restringido" domain="[('access_type', '=', 'restricted')]"/>
                <separator/>
                <filter name="group_user" string="Agrupar por usuario" context="{'group_by': 'user_id'}"/>
                <filter name="group_warehouse" string="Agrupar por almacén" context="{'group_by': 'warehouse_id'}"/>
                <filter name="group_access_type" string="Agrupar por tipo de acceso" context="{'group_by': 'access_type'}"/>
            </search>
        </field>
    </record>

    <!-- Acción de Ventana: Gestión de Accesos -->
    <record id="action_warehouse_access" model="ir.actions.act_window">
        <field name="name">Accesos a almacenes</field>
        <field name="res_model">amunet.warehouse.access</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Configure accesos a almacenes para usuarios
            </p>
            <p>
                Controle quién puede acceder a qué almacenes y qué operaciones pueden realizar.
                Las reglas de seguridad se generan automáticamente al guardar la configuración.
            </p>
        </field>
    </record>

    <!-- Menú: Configuración → Usuarios y Compañías → Accesos a Almacenes -->
    <menuitem id="menu_warehouse_access"
              name="Accesos a almacén"
              parent="base.menu_users"
              action="action_warehouse_access"
              sequence="50"
              groups="base.group_system"/>

    <!-- Vista de Lista: Reglas Generadas (modelo auxiliar) -->
    <record id="view_warehouse_access_rule_list" model="ir.ui.view">
        <field name="name">amunet.warehouse.access.rule.list</field>
        <field name="model">amunet.warehouse.access.rule</field>
        <field name="arch" type="xml">
            <list string="Reglas de acceso generadas" create="false" delete="false">
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="warehouse_id"/>
                <field name="model_name"/>
                <field name="domain_force" widget="text"/>
                <field name="access_type" widget="badge"/>
                <field name="active" widget="boolean_toggle"/>
                <button name="action_view_odoo_rule"
                        type="object"
                        icon="fa-external-link"
                        title="Ver regla de Odoo en configuración técnica"/>
            </list>
        </field>
    </record>

    <!-- Acción de Ventana: Vista de Reglas -->
    <record id="action_warehouse_access_rule" model="ir.actions.act_window">
        <field name="name">Reglas de acceso generadas</field>
        <field name="res_model">amunet.warehouse.access.rule</field>
        <field name="view_mode">list</field>
        <field name="context">{'search_default_filter_active': 1}</field>
    </record>

    <!-- Menú: Configuración Técnica → Seguridad → Reglas de Acceso a Almacenes -->
    <menuitem id="menu_warehouse_access_rule"
              name="Reglas de acceso a almacenes"
              parent="base.menu_security"
              action="action_warehouse_access_rule"
              sequence="15"
              groups="base.group_system"/>

</odoo>

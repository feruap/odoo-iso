<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mrp_production_form_change_control" model="ir.ui.view">
        <field name="name">mrp.production.form.change.control</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <field name="change_control_count" invisible="1"/>
                <button name="action_create_change_control"
                        string="Crear desviacion/cambio"
                        type="object"
                        class="btn-secondary"
                        groups="amunet_quality.group_quality_user,amunet_quality.group_quality_supervisor,amunet_quality.group_quality_manager,amunet_production.group_production_supervisor"/>
                <button name="action_view_change_controls"
                        string="Ver desviaciones/cambios"
                        type="object"
                        invisible="change_control_count == 0"/>
            </xpath>
        </field>
    </record>
</odoo>

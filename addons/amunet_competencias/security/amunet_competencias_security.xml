<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════
         Grupos de Seguridad — Gestión de Competencias
         ISO 13485 §6.2
    ══════════════════════════════════════════════════════ -->

    <!-- Grupo: Analista (lectura de sus propias capacitaciones) -->
    <record id="group_competencias_user" model="res.groups">
        <field name="name">Competencias / Analista</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">
            Puede ver sus propios registros de capacitación.
            No puede crear ni editar registros ajenos.
        </field>
    </record>

    <!-- Grupo: Gestor de Capacitación -->
    <record id="group_competencias_manager" model="res.groups">
        <field name="name">Competencias / Gestor de Capacitación</field>
        <field name="implied_ids" eval="[(4, ref('group_competencias_user'))]"/>
        <field name="comment">
            Puede crear, editar y cancelar cualquier registro de capacitación.
            Puede gestionar la Matriz de Competencias y los Cursos completos.
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Reglas de registro — Cursos e Intentos de examen
    ══════════════════════════════════════════════════════ -->

    <!-- Cursos: cualquier empleado ve solo los publicados -->
    <record id="rule_curso_publicado_user" model="ir.rule">
        <field name="name">Cursos: empleados ven solo publicados</field>
        <field name="model_id" ref="model_amunet_curso"/>
        <field name="domain_force">[('state', '=', 'publicado')]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Cursos: el gestor ve todos (borradores incluidos) -->
    <record id="rule_curso_manager" model="ir.rule">
        <field name="name">Cursos: gestor ve todos</field>
        <field name="model_id" ref="model_amunet_curso"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_competencias_manager'))]"/>
    </record>

    <!-- Intentos: cada empleado ve solo los propios -->
    <record id="rule_curso_intento_own" model="ir.rule">
        <field name="name">Intentos: solo los propios</field>
        <field name="model_id" ref="model_amunet_curso_intento"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Intentos: el gestor ve todos -->
    <record id="rule_curso_intento_manager" model="ir.rule">
        <field name="name">Intentos: gestor ve todos</field>
        <field name="model_id" ref="model_amunet_curso_intento"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_competencias_manager'))]"/>
    </record>

</odoo>

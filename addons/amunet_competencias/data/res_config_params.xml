<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!--
            Parámetro de sistema que controla el bloqueo de firma por competencia.
            Valor por defecto: False (comportamiento idéntico al sistema actual).
            Activar manualmente desde: Configuración > Técnico > Parámetros del Sistema
        -->
        <record id="param_signature_training_check" model="ir.config_parameter">
            <field name="key">amunet_competencias.signature_training_check_enabled</field>
            <field name="value">False</field>
        </record>

    </data>
</odoo>

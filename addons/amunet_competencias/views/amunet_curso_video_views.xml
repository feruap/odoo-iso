<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════
         Video de Curso — lista y formulario (reproductor embebido)
    ══════════════════════════════════════════════════════ -->
    <record id="view_amunet_curso_video_list" model="ir.ui.view">
        <field name="name">amunet.curso.video.list</field>
        <field name="model">amunet.curso.video</field>
        <field name="arch" type="xml">
            <list string="Videos">
                <field name="secuencia" widget="handle"/>
                <field name="name"/>
                <field name="video_url"/>
                <field name="video_filename" string="Archivo" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_amunet_curso_video_form" model="ir.ui.view">
        <field name="name">amunet.curso.video.form</field>
        <field name="model">amunet.curso.video</field>
        <field name="arch" type="xml">
            <form string="Video del curso">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Ej. Parte 1 — Introducción"/></h1>
                    </div>
                    <group>
                        <field name="video_url" widget="url"
                               placeholder="https://www.youtube.com/watch?v=..."/>
                        <field name="video_file" filename="video_filename" widget="binary"/>
                        <field name="video_filename" invisible="1"/>
                    </group>
                    <separator string="Reproductor"/>
                    <field name="embed_html" widget="html" readonly="1" nolabel="1"/>
                    <separator string="Notas del video"/>
                    <field name="descripcion" nolabel="1" placeholder="Notas opcionales sobre este video..."/>
                </sheet>
            </form>
        </field>
    </record>

</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════
         Vista: Registro de Capacitación — Formulario
    ══════════════════════════════════════════════════════ -->
    <record id="view_amunet_registro_capacitacion_form" model="ir.ui.view">
        <field name="name">amunet.registro.capacitacion.form</field>
        <field name="model">amunet.registro.capacitacion</field>
        <field name="arch" type="xml">
            <form string="Registro de Capacitación">
                <header>
                    <button name="action_cancelar" string="Cancelar"
                            type="object" class="btn-danger"
                            confirm="¿Desea cancelar este registro de capacitación?"
                            invisible="state == 'cancelada'"
                            groups="amunet_competencias.group_competencias_manager"/>
                    <button name="action_reactivar" string="Reactivar"
                            type="object" class="btn-success"
                            invisible="state != 'cancelada'"
                            groups="amunet_competencias.group_competencias_manager"/>
                    <button name="action_programar_renovacion" string="Programar renovación"
                            type="object" class="btn-primary"
                            invisible="state == 'cancelada'"
                            groups="amunet_competencias.group_competencias_manager"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="vigente,proxima,vencida"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box"/>

                    <!-- Alerta visual si está vencida -->
                    <div class="alert alert-danger" role="alert"
                         invisible="state != 'vencida'">
                        <strong>⚠️ Capacitación VENCIDA.</strong>
                        Este analista está BLOQUEADO para firmar controles de calidad
                        que usen el procedimiento o parámetro indicado.
                    </div>

                    <!-- Alerta si vence pronto -->
                    <div class="alert alert-warning" role="alert"
                         invisible="state != 'proxima'">
                        <strong>⏰ Capacitación por vencer.</strong>
                        Quedan <field name="days_to_expiry" readonly="1"/> días. Programe la renovación.
                    </div>

                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                    <group>
                        <group string="👤 Analista">
                            <field name="user_id" options="{'no_create': True}"/>
                            <field name="employee_id" readonly="1"/>
                            <field name="department_id" readonly="1"/>
                        </group>
                        <group string="📋 Alcance de la Capacitación">
                            <field name="procedure_id" options="{'no_create': True}"/>
                            <field name="parameter_id" options="{'no_create': True}"/>
                        </group>
                    </group>

                    <group>
                        <group string="📅 Fechas">
                            <field name="training_date"/>
                            <field name="expiry_date"/>
                            <field name="days_to_expiry" readonly="1"/>
                        </group>
                        <group string="🎓 Instructor y Modalidad">
                            <field name="trainer_id" options="{'no_create': True}"/>
                            <field name="training_type"/>
                        </group>
                    </group>

                    <group string="📎 Evidencia Documental">
                        <field name="certificate_file" widget="binary"
                               filename="certificate_filename"/>
                        <field name="certificate_filename" invisible="1"/>
                    </group>

                    <group string="📝 Observaciones">
                        <field name="notes" nolabel="1" colspan="2"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Vista: Lista de Registros de Capacitación
    ══════════════════════════════════════════════════════ -->
    <record id="view_amunet_registro_capacitacion_list" model="ir.ui.view">
        <field name="name">amunet.registro.capacitacion.list</field>
        <field name="model">amunet.registro.capacitacion</field>
        <field name="arch" type="xml">
            <list string="Registros de Capacitación"
                  decoration-danger="state == 'vencida'"
                  decoration-warning="state == 'proxima'"
                  decoration-success="state == 'vigente'">
                <field name="name"/>
                <field name="user_id"/>
                <field name="department_id"/>
                <field name="procedure_id"/>
                <field name="parameter_id"/>
                <field name="training_date"/>
                <field name="expiry_date"/>
                <field name="days_to_expiry" string="Días restantes"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'vigente'"
                       decoration-warning="state == 'proxima'"
                       decoration-danger="state == 'vencida'"
                       decoration-muted="state == 'cancelada'"/>
                <field name="trainer_id"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Vista: Búsqueda
    ══════════════════════════════════════════════════════ -->
    <record id="view_amunet_registro_capacitacion_search" model="ir.ui.view">
        <field name="name">amunet.registro.capacitacion.search</field>
        <field name="model">amunet.registro.capacitacion</field>
        <field name="arch" type="xml">
            <search string="Buscar Capacitaciones">
                <field name="name"/>
                <field name="user_id"/>
                <field name="procedure_id"/>
                <field name="parameter_id"/>
                <field name="trainer_id"/>
                <separator/>
                <filter name="vigentes" string="Vigentes"
                        domain="[('state', '=', 'vigente')]"/>
                <filter name="proximas" string="Por vencer (&lt; 30 días)"
                        domain="[('state', '=', 'proxima')]"/>
                <filter name="vencidas" string="Vencidas"
                        domain="[('state', '=', 'vencida')]"/>
                <filter name="pendientes_renovar" string="Pendientes de renovar"
                        domain="[('state', 'in', ['proxima', 'vencida'])]"/>
                <filter name="sin_evidencia" string="Sin evidencia"
                        domain="[('certificate_file', '=', False)]"/>
                <filter name="virtuales" string="Virtuales"
                        domain="[('training_type', '=', 'virtual')]"/>
                <filter name="externas" string="Externas"
                        domain="[('training_type', '=', 'externo')]"/>
                <separator/>
                <filter name="mis_capacitaciones" string="Mis capacitaciones"
                        domain="[('user_id', '=', uid)]"/>
                <separator/>
                <filter name="group_user" string="Agrupar por Analista" context="{'group_by': 'user_id'}"/>
                <filter name="group_procedure" string="Agrupar por Procedimiento" context="{'group_by': 'procedure_id'}"/>
                <filter name="group_state" string="Agrupar por Estado" context="{'group_by': 'state'}"/>
                <filter name="group_dept" string="Agrupar por Departamento" context="{'group_by': 'department_id'}"/>
                <filter name="group_training_type" string="Agrupar por Modalidad" context="{'group_by': 'training_type'}"/>
                <filter name="group_trainer" string="Agrupar por Instructor" context="{'group_by': 'trainer_id'}"/>
                <filter name="group_expiry_month" string="Agrupar por Mes de vencimiento" context="{'group_by': 'expiry_date:month'}"/>
            </search>
        </field>
    </record>

    <record id="view_amunet_registro_capacitacion_calendar" model="ir.ui.view">
        <field name="name">amunet.registro.capacitacion.calendar</field>
        <field name="model">amunet.registro.capacitacion</field>
        <field name="arch" type="xml">
            <calendar string="Calendario de Renovaciones"
                      date_start="expiry_date"
                      color="state"
                      event_open_popup="true"
                      quick_create="false"
                      mode="month">
                <field name="user_id"/>
                <field name="procedure_id"/>
                <field name="parameter_id"/>
                <field name="state"/>
                <field name="trainer_id"/>
            </calendar>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Acción de ventana
    ══════════════════════════════════════════════════════ -->
    <record id="action_amunet_registro_capacitacion" model="ir.actions.act_window">
        <field name="name">Registros de Capacitación</field>
        <field name="res_model">amunet.registro.capacitacion</field>
        <field name="view_mode">list,form,calendar</field>
        <field name="search_view_id" ref="view_amunet_registro_capacitacion_search"/>
        <field name="context">{'search_default_vigentes': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay registros de capacitación aún.
            </p>
            <p>
                Registre las capacitaciones de sus analistas para que el sistema
                pueda validar automáticamente su competencia al momento de firmar.
            </p>
        </field>
    </record>

    <record id="action_amunet_calendario_renovaciones" model="ir.actions.act_window">
        <field name="name">Calendario de Renovaciones</field>
        <field name="res_model">amunet.registro.capacitacion</field>
        <field name="view_mode">calendar,list,form</field>
        <field name="view_id" ref="view_amunet_registro_capacitacion_calendar"/>
        <field name="search_view_id" ref="view_amunet_registro_capacitacion_search"/>
        <field name="context">{'search_default_pendientes_renovar': 1}</field>
    </record>

    <record id="action_server_programar_renovacion" model="ir.actions.server">
        <field name="name">Programar renovación</field>
        <field name="model_id" ref="model_amunet_registro_capacitacion"/>
        <field name="binding_model_id" ref="model_amunet_registro_capacitacion"/>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">action = records.action_programar_renovacion()</field>
    </record>

</odoo>

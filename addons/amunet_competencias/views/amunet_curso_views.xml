<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════
         Curso — Formulario de gestión (Gestor de Capacitación)
    ══════════════════════════════════════════════════════ -->
    <record id="view_amunet_curso_form" model="ir.ui.view">
        <field name="name">amunet.curso.form</field>
        <field name="model">amunet.curso</field>
        <field name="arch" type="xml">
            <form string="Curso de Capacitación">
                <header>
                    <button name="action_publicar" string="Publicar" type="object"
                            class="btn-primary" invisible="state == 'publicado'"/>
                    <button name="action_volver_borrador" string="Volver a borrador"
                            type="object" invisible="state == 'borrador'"/>
                    <button name="action_marcar_revisado" string="Marcar revisión hecha"
                            type="object" class="btn-warning"
                            invisible="not revision_requerida"/>
                    <button name="action_iniciar_examen" string="Presentar examen (prueba)"
                            type="object" invisible="state != 'publicado'"/>
                    <field name="state" widget="statusbar" statusbar_visible="borrador,publicado"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_equipos" type="object"
                                class="oe_stat_button" icon="fa-wrench">
                            <field name="equipment_count" widget="statinfo" string="Equipos"/>
                        </button>
                        <button name="action_view_intentos" type="object"
                                class="oe_stat_button" icon="fa-pencil-square-o">
                            <field name="intento_count" widget="statinfo" string="Intentos"/>
                        </button>
                    </div>
                    <div class="alert alert-warning" role="alert"
                         invisible="not revision_requerida">
                        <strong>Revisión requerida.</strong>
                        <field name="revision_motivo" readonly="1" nolabel="1"/>
                        Revisa el contenido y el examen, luego pulsa “Marcar revisión hecha”.
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Ej. Operación del termociclador"/></h1>
                        <field name="code" readonly="1"/>
                    </div>
                    <group>
                        <group string="Evaluación">
                            <field name="calificacion_minima"/>
                            <field name="validez_meses"/>
                            <field name="tiempo_minimo_estudio"/>
                            <field name="tiempo_limite_examen"/>
                        </group>
                        <group string="Resumen">
                            <field name="total_preguntas"/>
                            <field name="video_count"/>
                            <field name="equipment_count" string="Equipos que lo requieren"/>
                            <field name="revision_requerida" readonly="1"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Contenido" name="contenido">
                            <separator string="Videos del curso"/>
                            <field name="video_ids"/>
                            <separator string="Material escrito"/>
                            <field name="descripcion" placeholder="Contenido escrito del curso..."/>
                        </page>
                        <page string="Material de apoyo (PDFs)" name="material">
                            <field name="material_ids" widget="many2many_binary"/>
                        </page>
                        <page string="Examen" name="examen">
                            <div class="alert alert-info" role="alert">
                                Agrega las preguntas. Abre cada pregunta (clic en la fila) para
                                capturar sus respuestas y marcar la correcta.
                            </div>
                            <field name="pregunta_ids">
                                <list string="Preguntas">
                                    <field name="secuencia" widget="handle"/>
                                    <field name="texto"/>
                                    <field name="puntos"/>
                                </list>
                                <form string="Pregunta">
                                    <group>
                                        <field name="texto"/>
                                        <field name="puntos"/>
                                    </group>
                                    <separator string="Respuestas (marca la correcta)"/>
                                    <field name="respuesta_ids">
                                        <list string="Respuestas" editable="bottom">
                                            <field name="texto"/>
                                            <field name="es_correcta" widget="boolean_toggle"/>
                                        </list>
                                    </field>
                                </form>
                            </field>
                        </page>
                        <page string="Alcance (PNOs y departamentos)" name="alcance">
                            <group>
                                <field name="procedure_ids" widget="many2many_tags"/>
                                <field name="departamento_ids" widget="many2many_tags"/>
                            </group>
                            <div class="alert alert-info" role="alert">
                                Los PNOs conectan el curso con las máquinas. Al aprobar el examen
                                se genera un registro de capacitación vigente para cada PNO listado.
                                Si no asignas departamentos, el curso aplica a todos los empleados.
                            </div>
                        </page>
                        <page string="Equipos relacionados" name="equipos">
                            <field name="equipment_ids" readonly="1">
                                <list string="Equipos">
                                    <field name="name"/>
                                    <field name="department"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Curso — Lista de gestión -->
    <record id="view_amunet_curso_list" model="ir.ui.view">
        <field name="name">amunet.curso.list</field>
        <field name="model">amunet.curso</field>
        <field name="arch" type="xml">
            <list string="Cursos" decoration-warning="revision_requerida">
                <field name="code"/>
                <field name="name"/>
                <field name="video_count" string="Videos"/>
                <field name="total_preguntas"/>
                <field name="calificacion_minima"/>
                <field name="validez_meses"/>
                <field name="equipment_count" string="Equipos"/>
                <field name="revision_requerida" string="Rev."/>
                <field name="state" widget="badge"
                       decoration-success="state == 'publicado'"
                       decoration-muted="state == 'borrador'"/>
            </list>
        </field>
    </record>

    <!-- Curso — Búsqueda -->
    <record id="view_amunet_curso_search" model="ir.ui.view">
        <field name="name">amunet.curso.search</field>
        <field name="model">amunet.curso</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="procedure_ids"/>
                <filter name="f_publicado" string="Publicados"
                        domain="[('state', '=', 'publicado')]"/>
                <filter name="f_borrador" string="Borradores"
                        domain="[('state', '=', 'borrador')]"/>
                <filter name="f_revision" string="Revisión requerida"
                        domain="[('revision_requerida', '=', True)]"/>
            </search>
        </field>
    </record>

    <!-- Curso — Formulario simplificado para el empleado -->
    <record id="view_amunet_curso_form_empleado" model="ir.ui.view">
        <field name="name">amunet.curso.form.empleado</field>
        <field name="model">amunet.curso</field>
        <field name="arch" type="xml">
            <form string="Curso" create="false" edit="false">
                <header>
                    <button name="action_comenzar_estudio" string="Comenzar el curso"
                            type="object" class="btn-primary"
                            invisible="tiempo_minimo_estudio == 0 or mi_estudio_inicio"/>
                    <button name="action_iniciar_examen" string="Presentar examen"
                            type="object" class="btn-primary"
                            invisible="not mi_puede_examinar"/>
                </header>
                <sheet>
                    <field name="tiempo_minimo_estudio" invisible="1"/>
                    <field name="mi_estudio_inicio" invisible="1"/>
                    <field name="mi_puede_examinar" invisible="1"/>
                    <div class="alert alert-info" role="alert"
                         invisible="not mi_estudio_mensaje">
                        <field name="mi_estudio_mensaje" readonly="1" nolabel="1"/>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                        <field name="code" readonly="1"/>
                    </div>
                    <group>
                        <group>
                            <field name="mi_estado" readonly="1"/>
                            <field name="total_preguntas" readonly="1"/>
                        </group>
                        <group>
                            <field name="calificacion_minima" readonly="1"/>
                            <field name="validez_meses" readonly="1"/>
                        </group>
                    </group>
                    <separator string="Videos del curso"/>
                    <field name="video_ids" readonly="1"/>
                    <separator string="Contenido"/>
                    <field name="descripcion" readonly="1"/>
                    <separator string="Material de apoyo"/>
                    <field name="material_ids" widget="many2many_binary" readonly="1"/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Acción — Cursos (gestión) -->
    <record id="action_amunet_curso" model="ir.actions.act_window">
        <field name="name">Cursos</field>
        <field name="res_model">amunet.curso</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_amunet_curso_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Crea tu primer curso de capacitación</p>
            <p>Cada curso reúne videos, material PDF y el examen. Al aprobar,
               se genera el registro de capacitación.</p>
        </field>
    </record>

</odoo>
